---
const {
  title = 'Guillermo Laporta',
  description = 'Guillermo Laporta is a flutist, composer and cultural producer based in New York City and Asturias, Spain. Founder of CreArtBox and Festival ADAR.',
} = Astro.props;

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';

const navLinks = [
  { href: `${b}portfolio/`,   label: 'Compositions' },
  { href: `${b}visual-art/`,  label: 'Visual Art' },
  { href: `${b}catalogue/`,   label: 'Catalogue' },
  { href: `${b}calendar/`,    label: 'Calendar' },
  { href: `${b}discography/`, label: 'Recordings' },
  { href: `${b}archive/`,     label: 'Archive' },
  { href: `${b}press/`,       label: 'Press' },
  { href: `${b}bio/`,         label: 'About' },
  { href: `${b}resume/`,      label: 'Resume' },
];

const mobileNav = [
  { href: b,                   label: 'Home',         icon: '<svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5"/><path d="M5.5 10.5V20h4.5v-5h4v5h4.5v-9.5"/></svg>' },
  { href: `${b}portfolio/`,    label: 'Compositions', icon: '<svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>' },
  { href: `${b}visual-art/`,   label: 'Visual Art',   icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m16.2 7.8-2 6.3-6.4 2.1 2-6.3z"/></svg>' },
  { href: `${b}resume/`,       label: 'Resume',       icon: '<svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8M16 17H8M10 9H8"/></svg>' },
  { href: `${b}bio/`,          label: 'About',        icon: '<svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4.5 21a7.5 7.5 0 0 1 15 0"/></svg>' },
];

const path = Astro.url.pathname;
function isActive(href) {
  if (href === b) return path === b || path === b.replace(/\/$/, '');
  return path === href || path.startsWith(href);
}
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#F6F2EA" />
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://gaawi.github.io${path}`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://gaawi.github.io${b}images/2023-03-architecture.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${b}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,300;1,9..144,400&family=Manrope:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap" />
    <title>{title}</title>
    <style is:global>
/* ── variables ──────────────────────────────────────────── */
:root{--bg:#F6F2EA;--paper:#FBF8F1;--bg-warm:#EFE8DA;--ink:#1A1614;--ink-2:#3A322D;--muted:#7A716A;--line:#D4CDBE;--line-soft:#E5DECF;--accent:#8A4B2B;--accent-2:#2F4A4A;--gold:#B89968;--serif:"Fraunces","Times New Roman",serif;--sans:"Manrope",system-ui,sans-serif;--mono:"JetBrains Mono",monospace}
/* ── reset ──────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--ink)}
body{font-family:var(--sans);font-size:15px;line-height:1.55;font-weight:350;-webkit-font-smoothing:antialiased;letter-spacing:-.005em}
img{display:block;max-width:100%;height:auto}
a{color:inherit;text-decoration:none}
button{font:inherit;cursor:pointer}
/* ── topbar (desktop) ────────────────────────────────────── */
.topbar{position:sticky;top:0;z-index:50;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:32px;padding:18px 40px;background:color-mix(in srgb,var(--bg) 88%,transparent);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--line-soft)}
.brand{display:flex;align-items:center;gap:12px;font-family:var(--serif);font-size:22px;font-weight:400;letter-spacing:-.01em}
.brand .glyph{width:34px;height:34px;border-radius:50%;background:var(--ink);color:var(--paper);display:grid;place-items:center;font-family:var(--serif);font-style:italic;font-size:18px;font-weight:400;flex-shrink:0}
.brand .name{font-style:italic}
.brand .name b{font-style:normal;font-weight:400}
.topnav ul{list-style:none;display:flex;gap:28px;justify-content:center;font-size:14px;font-weight:400;color:var(--ink-2)}
.topnav a{position:relative;padding:6px 0;transition:color .2s}
.topnav a:hover{color:var(--accent)}
.topnav a.active{color:var(--ink)}
.topnav a.active::after{content:"";position:absolute;left:50%;bottom:-2px;width:4px;height:4px;border-radius:50%;background:var(--accent);transform:translate(-50%)}
.topbar-right{display:flex;gap:14px;align-items:center;font-size:13px}
.tag-now{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border:1px solid var(--line);border-radius:999px;background:var(--paper);font-size:12px;color:var(--ink-2)}
.tag-now .pulse{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulse 2.5s ease-out infinite;flex-shrink:0}
@keyframes pulse{0%{box-shadow:0 0 0 0 color-mix(in srgb,var(--accent) 50%,transparent)}70%{box-shadow:0 0 0 8px transparent}to{box-shadow:0 0 0 0 transparent}}
/* ── pill nav (mobile bottom bar) ───────────────────────── */
.pill-nav{display:none;position:fixed;bottom:0;left:0;right:0;z-index:60;padding:8px 12px env(safe-area-inset-bottom,8px);background:color-mix(in srgb,var(--paper) 95%,transparent);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(--line-soft)}
.pill-nav-inner{display:flex;justify-content:space-around;align-items:center;gap:4px}
.pill-item{display:flex;flex-direction:column;align-items:center;gap:4px;padding:6px 8px;border-radius:14px;min-width:52px;color:var(--muted);transition:color .2s,background .2s;border:none;background:transparent;font-size:10px;font-weight:500;text-transform:uppercase;letter-spacing:.06em;font-family:var(--mono)}
.pill-item svg{width:22px;height:22px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.pill-item:hover{color:var(--ink);background:var(--bg-warm)}
.pill-item.active{color:var(--accent)}
/* ── hero ────────────────────────────────────────────────── */
.hero{padding:60px 40px 40px;position:relative}
.hero-grid{display:grid;grid-template-columns:1.3fr 1fr;gap:56px;align-items:end;max-width:1480px;margin:0 auto}
.hero-left{padding-bottom:12px}
.hero-eyebrow{display:inline-flex;align-items:center;gap:12px;font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:32px}
.hero-eyebrow .line{width:28px;height:1px;background:var(--muted)}
.hero-title{font-family:var(--serif);font-weight:300;font-size:clamp(64px,9.5vw,152px);line-height:.92;letter-spacing:-.035em;color:var(--ink)}
.hero-title .row{display:block}
.hero-title em{font-style:italic;font-weight:300;color:var(--accent)}
.hero-sub{margin-top:36px;max-width:46ch;font-size:17px;line-height:1.6;color:var(--ink-2);font-weight:350}
.hero-sub b{color:var(--ink);font-weight:500}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:32px}
/* ── hero card (featured image) ─────────────────────────── */
.hero-card{background:var(--paper);border:1px solid var(--line);border-radius:4px;padding:0;overflow:hidden;box-shadow:0 30px 60px -30px rgba(40,30,20,.18)}
.hero-card .img{aspect-ratio:4/5;background:var(--bg-warm);overflow:hidden;position:relative}
.hero-card .img img{width:100%;height:100%;object-fit:cover;filter:contrast(1.02) saturate(.94);transition:transform 1.2s cubic-bezier(.2,.8,.2,1)}
.hero-card:hover .img img{transform:scale(1.04)}
.hero-card .body{padding:18px 22px 22px;display:grid;grid-template-columns:1fr auto;gap:12px;align-items:end}
.hero-card .meta{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.hero-card h3{font-family:var(--serif);font-weight:400;font-size:26px;line-height:1.05;letter-spacing:-.015em}
.hero-card .where{font-size:12px;color:var(--muted);margin-top:6px}
.hero-card .badge{font-family:var(--mono);font-size:10px;padding:6px 10px;border:1px solid var(--line);border-radius:999px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink-2);background:var(--bg-warm);white-space:nowrap}
/* ── buttons ─────────────────────────────────────────────── */
.btn{display:inline-flex;align-items:center;gap:12px;padding:14px 22px;border:1px solid var(--line);border-radius:999px;background:var(--paper);color:var(--ink);font-size:14px;font-weight:500;cursor:pointer;transition:all .25s ease}
.btn:hover{background:var(--ink);color:var(--paper);border-color:var(--ink);transform:translateY(-1px)}
.btn.primary{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.btn.primary:hover{background:var(--accent);border-color:var(--accent)}
.btn .arr{display:inline-block;transition:transform .25s}
.btn:hover .arr{transform:translate(3px)}
/* ── section ─────────────────────────────────────────────── */
.section{padding:96px 40px;max-width:1480px;margin:0 auto}
.section-head{display:grid;grid-template-columns:1fr auto;align-items:end;gap:40px;margin-bottom:56px;padding-bottom:24px;border-bottom:1px solid var(--line-soft)}
.section-head .lhs{display:flex;flex-direction:column;gap:10px}
.section-num{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.section-title{font-family:var(--serif);font-weight:300;font-size:clamp(40px,5.6vw,84px);line-height:.96;letter-spacing:-.03em}
.section-title em{font-style:italic;color:var(--accent);font-weight:300}
.section-rhs{max-width:38ch;text-align:right;color:var(--muted);font-size:14px;line-height:1.55}
/* ── subpage head ────────────────────────────────────────── */
.subpage-head{padding:48px 56px 56px;border-bottom:1px solid var(--line-soft);margin-bottom:64px}
.subpage-back{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:32px;transition:color .2s}
.subpage-back:hover{color:var(--accent)}
.subpage-num{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.subpage-title{font-family:var(--serif);font-weight:300;font-size:clamp(48px,8vw,96px);line-height:1;letter-spacing:-.025em;color:var(--ink);margin-bottom:18px}
.subpage-title em{font-style:italic;color:var(--accent);font-weight:300}
.subpage-sub{font-size:16px;line-height:1.55;color:var(--ink-2);font-weight:350;max-width:60ch}
/* ── statement ───────────────────────────────────────────── */
.statement{display:grid;grid-template-columns:1fr 1.2fr;gap:80px;align-items:start}
.quote-mark{font-family:var(--serif);font-style:italic;font-weight:300;font-size:220px;line-height:.7;color:var(--gold);opacity:.45}
.statement-body{font-family:var(--serif);font-weight:300;font-size:clamp(22px,2.1vw,30px);line-height:1.4;color:var(--ink);letter-spacing:-.01em}
.statement-body p+p{margin-top:22px;color:var(--ink-2);font-size:.85em}
.statement-body em{font-style:italic;color:var(--accent)}
.statement-sig{margin-top:28px;font-family:var(--mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
/* ── calendar ────────────────────────────────────────────── */
.calendar{background:var(--paper);border:1px solid var(--line);border-radius:6px;overflow:hidden}
.cal-year{margin-bottom:56px}
.cal-year:last-child{margin-bottom:0}
.cal-year-label{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);padding-bottom:12px;border-bottom:1px solid var(--line-soft);margin-bottom:18px;font-weight:500}
.cal-row{display:grid;grid-template-columns:60px 130px 1fr 220px 120px;gap:24px;padding:26px 32px;border-bottom:1px solid var(--line-soft);align-items:center;cursor:pointer;transition:background .25s,padding .25s}
.cal-row:last-child{border-bottom:none}
.cal-row:hover{background:var(--bg-warm);padding-left:40px}
.cal-row .ix{font-family:var(--mono);font-size:11px;color:var(--muted)}
.cal-row .when{font-family:var(--serif);font-size:22px;line-height:1;letter-spacing:-.015em}
.cal-row .when small{display:block;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-top:6px;font-weight:400}
.cal-row .name{font-family:var(--serif);font-size:24px;font-weight:400;line-height:1.15;letter-spacing:-.015em}
.cal-row .name small{display:block;font-family:var(--sans);font-size:13px;color:var(--muted);font-weight:350;margin-top:4px;letter-spacing:0}
.cal-row .venue{font-size:13px;color:var(--ink-2);line-height:1.45}
.cal-row .status{text-align:right;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase}
.cal-row .status .pill{display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:999px;background:var(--ink);color:var(--paper)}
.cal-row .arr{display:inline-block;transition:transform .25s;margin-left:4px}
.cal-row:hover .arr{transform:translate(4px)}
/* ── visual art grid (portfolio) ─────────────────────────── */
.va-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:36px 24px}
.va-card{display:flex;flex-direction:column;cursor:pointer;transition:transform .25s ease}
.va-card:hover{transform:translateY(-2px)}
.va-img{position:relative;aspect-ratio:4/3;border-radius:3px;overflow:hidden;background:var(--bg-warm);margin-bottom:14px;box-shadow:0 6px 20px -10px rgba(40,30,20,.2)}
.va-img img{width:100%;height:100%;object-fit:cover;transition:transform 1s cubic-bezier(.2,.8,.2,1)}
.va-card:hover .va-img img{transform:scale(1.03)}
.va-num{position:absolute;top:10px;left:12px;font-family:var(--mono);font-size:9px;letter-spacing:.16em;text-transform:uppercase;background:rgba(251,248,241,.92);color:var(--ink);padding:3px 7px;border-radius:999px;backdrop-filter:blur(4px)}
.va-meta{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
.va-title{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.15;letter-spacing:-.015em;color:var(--ink);margin-bottom:6px}
.va-desc{font-size:13px;line-height:1.55;color:var(--ink-2);font-weight:350;flex:1}
.va-link{display:inline-flex;align-items:center;gap:6px;margin-top:10px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:500}
.va-link:hover{text-decoration:underline}
.archive-controls{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px}
.chip{padding:8px 16px;border:1px solid var(--line);border-radius:999px;background:var(--paper);color:var(--ink-2);font-size:13px;cursor:pointer;transition:all .2s;font-family:var(--sans)}
.chip:hover{background:var(--bg-warm);border-color:var(--ink)}
.chip.active{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.chip .count{font-family:var(--mono);font-size:10px;margin-left:8px;opacity:.7}
/* ── catalogue grid ──────────────────────────────────────── */
.catalogue-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px 64px}
.cat-heading{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding-bottom:12px;border-bottom:1px solid var(--line-soft);margin-bottom:16px;font-weight:500}
.cat-list{list-style:none;display:flex;flex-direction:column}
.cat-list li{display:grid;grid-template-columns:1.2fr 1fr;gap:16px;padding:14px 0;border-bottom:1px solid var(--line-soft);align-items:baseline}
.cat-list li:last-child{border-bottom:none}
.cat-list .cat-title{font-family:var(--serif);font-size:19px;font-weight:400;line-height:1.25;letter-spacing:-.01em;color:var(--ink)}
.cat-list .cat-forces{font-size:13px;color:var(--muted);text-align:right}
/* ── discography ─────────────────────────────────────────── */
.disco-section-label{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:24px;padding-bottom:12px;border-bottom:1px solid var(--line-soft);font-weight:500}
.disco-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px}
.disco-grid-dense{grid-template-columns:repeat(4,1fr);gap:24px}
.disco-card{display:flex;flex-direction:column;gap:12px;cursor:pointer;transition:transform .25s ease}
.disco-card:hover{transform:translateY(-3px)}
.disco-cover{aspect-ratio:1/1;overflow:hidden;border-radius:4px;background:var(--bg-warm);box-shadow:0 8px 24px -8px rgba(40,30,20,.18);position:relative}
.disco-cover img{width:100%;height:100%;object-fit:cover;transition:transform 1.2s cubic-bezier(.2,.8,.2,1)}
.disco-card:hover .disco-cover img{transform:scale(1.04)}
.disco-meta{display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-top:4px}
.disco-title{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.15;letter-spacing:-.015em;color:var(--ink)}
.disco-artist{font-size:13px;color:var(--muted)}
.disco-cta{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:4px}
/* ── archive grid ────────────────────────────────────────── */
.archive-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:28px 24px}
.arch-card{cursor:pointer;display:flex;flex-direction:column;gap:12px;transition:opacity .25s}
.arch-img{background:var(--bg-warm);border-radius:3px;aspect-ratio:4/5;overflow:hidden;border:1px solid var(--line-soft)}
.arch-img img{width:100%;height:100%;object-fit:cover;filter:contrast(1.02) saturate(.94);transition:transform .8s cubic-bezier(.2,.8,.2,1)}
.arch-card:hover .arch-img img{transform:scale(1.05)}
.arch-meta{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);display:flex;justify-content:space-between}
.arch-title{font-family:var(--serif);font-size:19px;font-weight:400;line-height:1.15;letter-spacing:-.012em}
.arch-venue{font-size:12px;color:var(--muted);line-height:1.4}
/* ── press grid ──────────────────────────────────────────── */
.press-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.press-card{background:var(--paper);border:1px solid var(--line);border-radius:4px;padding:28px 24px;display:flex;flex-direction:column;gap:14px;transition:all .2s ease}
.press-card:hover{border-color:color-mix(in srgb,var(--accent) 40%,var(--line));transform:translateY(-2px);box-shadow:0 12px 28px -16px rgba(40,30,20,.22)}
.press-mark{font-family:var(--serif);font-size:56px;line-height:.4;color:color-mix(in srgb,var(--accent) 70%,var(--muted));font-style:italic;height:14px;font-weight:300}
.press-quote{font-family:var(--serif);font-size:18px;line-height:1.4;font-weight:400;letter-spacing:-.012em;color:var(--ink);font-style:italic;flex:1}
.press-source{font-family:var(--mono);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:4px;padding-top:14px;border-top:1px solid var(--line-soft);font-weight:500}
/* ── leadership grid ─────────────────────────────────────── */
.leadership-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:72px}
.lead-card{padding:32px;background:var(--paper);border:1px solid var(--line);border-radius:4px;display:flex;flex-direction:column;gap:16px}
.lead-head{display:flex;flex-direction:column;gap:4px;padding-bottom:16px;border-bottom:1px solid var(--line-soft)}
.lead-org{font-family:var(--serif);font-size:28px;line-height:1.05;letter-spacing:-.015em;font-weight:400;color:var(--ink)}
.lead-period{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.lead-role{font-size:13px;color:var(--ink-2);font-weight:500}
.lead-body{font-size:14px;line-height:1.6;color:var(--ink-2);font-weight:350;flex:1}
.lead-link{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-top:auto;display:inline-flex;align-items:center;gap:6px}
.lead-link:hover{text-decoration:underline}
/* ── bio strip ───────────────────────────────────────────── */
.biostrip{background:var(--paper);border:1px solid var(--line);border-radius:6px;padding:56px;display:grid;grid-template-columns:1fr 1.3fr;gap:64px;align-items:start}
.biostrip-text h3{font-family:var(--serif);font-weight:300;font-size:clamp(36px,4vw,56px);line-height:.98;letter-spacing:-.025em;margin-bottom:28px}
.biostrip-text h3 em{font-style:italic;color:var(--accent)}
.biostrip-text p{font-size:15px;line-height:1.65;color:var(--ink-2);margin-bottom:16px;max-width:56ch}
.bio-stats{margin-top:40px;display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--line);padding-top:28px}
.stat{padding-right:16px}
.stat+.stat{border-left:1px solid var(--line-soft);padding-left:24px}
.stat .num{font-family:var(--serif);font-weight:300;font-size:52px;line-height:.95;letter-spacing:-.03em}
.stat .num em{font-style:italic;color:var(--accent)}
.stat .lbl{margin-top:8px;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.bio-side{display:grid;gap:16px}
.bio-card{border:1px solid var(--line-soft);border-radius:4px;padding:24px;background:var(--bg-warm)}
.bio-card .lbl{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
.bio-card .val{font-family:var(--serif);font-weight:400;font-size:22px;line-height:1.2;letter-spacing:-.015em}
.bio-card .val em{font-style:italic;color:var(--accent)}
.bio-card .desc{margin-top:8px;font-size:13px;color:var(--muted)}
.bio-card.dark{background:var(--ink);color:var(--paper);border-color:var(--ink)}
.bio-card.dark .lbl{color:color-mix(in srgb,var(--paper) 60%,transparent)}
.bio-card.dark .desc{color:color-mix(in srgb,var(--paper) 70%,transparent)}
.bio-card.dark .val em{color:var(--gold)}
/* ── lightbox ────────────────────────────────────────────── */
.lightbox{position:fixed;inset:0;background:rgba(15,12,10,.92);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);display:none;z-index:200;padding:5vh 5vw;overflow:auto}
.lightbox.open{display:grid;place-items:center}
.lightbox-inner{max-width:1100px;width:100%;background:var(--paper);border:1px solid var(--line);border-radius:4px;overflow:hidden;display:grid;grid-template-columns:1.2fr 1fr}
.lightbox-img{background:var(--bg-warm);min-height:60vh}
.lightbox-img img{width:100%;height:100%;object-fit:cover}
.lightbox-body{padding:40px;display:flex;flex-direction:column;gap:16px}
.lightbox-body .meta{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.lightbox-body h2{font-family:var(--serif);font-weight:300;font-size:48px;line-height:1;letter-spacing:-.025em}
.lightbox-body h2 em{font-style:italic;color:var(--accent)}
.lightbox-body .where{font-size:14px;color:var(--ink-2)}
.lightbox-body p{font-size:15px;line-height:1.6;color:var(--ink-2)}
.lightbox-body .lb-actions{display:flex;gap:8px;margin-top:auto}
.lightbox-close{position:absolute;top:24px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--paper);border:1px solid var(--line);color:var(--ink);cursor:pointer;display:grid;place-items:center;font-size:18px;transition:all .2s}
.lightbox-close:hover{background:var(--ink);color:var(--paper)}
/* ── footer ──────────────────────────────────────────────── */
.footer{background:var(--ink);color:var(--paper);padding:80px 40px 32px}
.footer-inner{max-width:1480px;margin:0 auto}
.footer-mark{font-family:var(--serif);font-weight:300;font-size:clamp(56px,9vw,132px);line-height:.92;letter-spacing:-.035em;padding-bottom:48px;border-bottom:1px solid #3A332A;margin-bottom:48px}
.footer-mark em{font-style:italic;color:var(--gold);font-weight:300}
.footer-mark .arr{color:var(--accent)}
.footer-grid{display:grid;grid-template-columns:1.3fr 1fr 1fr 1fr;gap:56px;padding-bottom:48px}
.footer h4{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#968d7e;margin-bottom:18px;font-weight:400}
.footer p{font-size:14px;line-height:1.6;color:#d8cfbc;max-width:36ch}
.footer a{color:#d8cfbc;transition:color .2s}
.footer a:hover{color:var(--gold)}
.footer ul{list-style:none;display:grid;gap:8px;font-size:14px}
.footer-bottom{padding-top:24px;border-top:1px solid #3A332A;display:flex;justify-content:space-between;font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#8a8378}
/* ── va list (portfolio detail) ──────────────────────────── */
.va-list-section{margin-top:80px}
.va-list-heading{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding-bottom:14px;border-bottom:1px solid var(--line-soft);margin-bottom:4px;font-weight:500}
.va-list-intro{font-size:14px;line-height:1.6;color:var(--ink-2);margin-top:16px;margin-bottom:24px;max-width:70ch}
.va-list{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:0 56px}
.va-list li{display:grid;grid-template-columns:1fr auto auto;gap:12px 18px;align-items:baseline;padding:12px 0;border-bottom:1px solid var(--line-soft)}
.va-list .vl-composer{font-family:var(--serif);font-size:16px;font-weight:500;color:var(--ink)}
.va-list .vl-work{font-size:13px;color:var(--ink-2);font-style:italic;grid-column:1;grid-row:2;margin-top:-6px;font-weight:350}
.va-list .vl-year{font-family:var(--mono);font-size:11px;letter-spacing:.06em;color:var(--muted);grid-row:1}
.va-list .vl-status{font-family:var(--mono);font-size:9px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);padding:3px 8px;border:1px solid var(--line);border-radius:999px;grid-row:1}
/* ── focus ───────────────────────────────────────────────── */
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:2px}
img[loading=lazy]{background:var(--bg-warm)}
/* ── responsive ──────────────────────────────────────────── */
@media(max-width:1100px){
  .hero-grid{grid-template-columns:1fr}
  .archive-grid{grid-template-columns:repeat(3,1fr)}
  .disco-grid-dense{grid-template-columns:repeat(3,1fr)}
  .biostrip{grid-template-columns:1fr;padding:32px;gap:32px}
  .footer-grid{grid-template-columns:1fr 1fr}
  .section{padding:64px 24px}
  .topbar{padding:14px 20px}
  .topnav{display:none}
  .cal-row{grid-template-columns:1fr;gap:12px;padding:22px}
  .cal-row .status{text-align:left}
  .lightbox-inner{grid-template-columns:1fr}
  .catalogue-grid{grid-template-columns:1fr;gap:40px}
  .leadership-grid{grid-template-columns:1fr}
  .disco-grid{grid-template-columns:1fr}
  .press-grid{grid-template-columns:repeat(2,1fr)}
  .va-grid{grid-template-columns:repeat(2,1fr);gap:32px 20px}
}
@media(max-width:720px){
  .topbar{display:none}
  .pill-nav{display:flex;flex-direction:column}
  body{padding-bottom:calc(72px + env(safe-area-inset-bottom,0px))}
  .hero{padding:32px 20px 20px}
  .hero-grid{gap:32px}
  .hero-eyebrow{margin-bottom:20px}
  .hero-title{font-size:clamp(48px,13vw,80px)}
  .hero-sub{margin-top:24px;font-size:16px}
  .hero-actions{margin-top:24px}
  .section{padding:56px 20px}
  .section-head{grid-template-columns:1fr;gap:20px;margin-bottom:36px}
  .section-rhs{text-align:left;max-width:100%}
  .subpage-head{padding:32px 20px 36px;margin-bottom:36px}
  .subpage-back{margin-bottom:24px}
  .subpage-title{font-size:clamp(36px,11vw,56px)}
  .statement{grid-template-columns:1fr;gap:20px}
  .quote-mark{font-size:60px}
  .statement-body p{font-size:18px}
  .biostrip{padding:24px;gap:24px}
  .biostrip-text h3{font-size:26px}
  .bio-stats{grid-template-columns:repeat(2,1fr);gap:16px}
  .catalogue-grid{gap:32px}
  .cat-list li{grid-template-columns:1fr;gap:4px;padding:12px 0}
  .cat-list .cat-forces{text-align:left}
  .cat-list .cat-title{font-size:17px}
  .lead-card{padding:24px}
  .lead-org{font-size:24px}
  .cal-row .ix{display:none}
  .cal-row .when{font-size:14px}
  .cal-row .name{font-size:18px}
  .archive-grid{grid-template-columns:repeat(2,1fr);gap:16px}
  .arch-title{font-size:14px}
  .va-grid{grid-template-columns:1fr;gap:28px}
  .va-title{font-size:19px}
  .press-grid{grid-template-columns:1fr;gap:14px}
  .press-card{padding:24px 22px}
  .press-quote{font-size:16px}
  .disco-grid-dense{grid-template-columns:repeat(2,1fr);gap:16px}
  .footer{padding:48px 20px 32px}
  .footer-mark{font-size:36px;line-height:1.05}
  .footer-grid{grid-template-columns:1fr;gap:32px}
  .lightbox{padding:0}
  .lightbox-inner{max-height:100vh;border-radius:0}
  .lightbox-img{aspect-ratio:4/3}
  .lightbox-body{padding:24px}
  .lightbox-body h2{font-size:28px}
}
@media print{.topbar,.pill-nav,.lightbox{display:none!important}body{background:#fff;color:#000;padding-bottom:0}}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}}
    </style>
  </head>
  <body>

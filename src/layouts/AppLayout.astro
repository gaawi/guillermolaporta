        </span>
      </div>
    </header>

    <slot />

    <footer class="footer" id="contact">
      <div class="footer-inner">
        <div class="footer-mark">
          Let's make <em>something</em><br />
          patient and <em>true</em>. <span class="arr">→</span>
        </div>
        <div class="footer-grid">
          <div>
            <h4>Studio</h4>
            <p>Guillermo Laporta is open to commissions, artistic direction and collaboration with film, dance and contemporary ensembles.</p>
            <p style="margin-top:16px"><a href="mailto:guillermo@creartbox.nyc">guillermo@creartbox.nyc</a></p>
          </div>
          <div>
            <h4>Sections</h4>
            <ul>
              {navLinks.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <h4>Companies</h4>
            <ul>
              <li><a href="https://creartbox.nyc" target="_blank" rel="noopener">CreArtBox · NYC</a></li>
              <li><a href="https://festivaladar.com" target="_blank" rel="noopener">Festival ADAR · Spain</a></li>
            </ul>
          </div>

---
const {
  title = 'Guillermo Laporta',
  description = 'Guillermo Laporta is a flutist, composer, designer and multimedia artist based between New York City and Asturias.',
  eyebrow = 'Flutist / Composer / Designer'
} = Astro.props;

const nav = [
  ['/', 'Home'],
  ['/calendar/', 'Calendar'],
  ['/portfolio/', 'Portfolio'],
  ['/catalogue/', 'Catalogue'],
  ['/discography/', 'Discography'],
  ['/images/', 'Images'],
  ['/bio/', 'Bio'],
  ['/contact/', 'Contact']
];
---
<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='description' content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --black: #050505;
        --white: #f5f1e8;
        --paper: #eee7dc;
        --brown: #8a5f37;
        --brown-dark: #342315;
        --clay: #b78b60;
        --ink: #111111;
        --muted: rgba(245, 241, 232, 0.66);
        --muted-dark: rgba(5, 5, 5, 0.62);
        --line: rgba(245, 241, 232, 0.18);
        --line-dark: rgba(5, 5, 5, 0.14);
        --max: 1240px;
        --radius: 0px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--black);
        color: var(--white);
        font-family: Arial, Helvetica, sans-serif;
        text-rendering: geometricPrecision;
      }

      a { color: inherit; text-decoration: none; }
      p { line-height: 1.6; }

      .site-shell {
        min-height: 100svh;
        background:
          linear-gradient(90deg, rgba(245,241,232,.035) 1px, transparent 1px),
          linear-gradient(180deg, rgba(245,241,232,.035) 1px, transparent 1px),
          var(--black);
        background-size: 72px 72px;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(5, 5, 5, 0.88);
        backdrop-filter: blur(16px);
        border-bottom: 2px solid var(--white);
      }

      .nav {
        width: min(var(--max), calc(100% - 24px));
        margin: 0 auto;
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand {
        display: grid;
        gap: 2px;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: -0.04em;
        font-size: clamp(1.05rem, 2vw, 1.55rem);
        line-height: 0.9;
      }

      .brand small {
        color: var(--clay);
        letter-spacing: 0.12em;
        font-size: 0.58rem;
        font-weight: 800;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .nav-links a {
        border: 1px solid var(--line);
        padding: 9px 11px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.68rem;
        font-weight: 800;
        color: var(--muted);
      }

      .nav-links a:hover { color: var(--black); background: var(--white); }

      .page {
        width: min(var(--max), calc(100% - 24px));
        margin: 0 auto;
      }

      .page-hero {
        min-height: 58svh;
        padding: 82px 0 54px;
        display: grid;
        align-items: end;
        border-bottom: 2px solid var(--white);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.72rem;
        font-weight: 900;
      }

      .eyebrow::before { content: ''; width: 42px; height: 2px; background: var(--clay); }

      h1, h2, h3 {
        margin: 0;
        font-family: Arial Black, Arial, Helvetica, sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.085em;
      }

      h1 {
        max-width: 1100px;
        font-size: clamp(4.2rem, 15vw, 14rem);
        line-height: 0.72;
      }

      h2 {
        font-size: clamp(2.8rem, 8vw, 7.5rem);
        line-height: 0.78;
      }

      h3 {
        font-size: clamp(1.8rem, 4vw, 3.7rem);
        line-height: 0.82;
      }

      .intro {
        max-width: 820px;
        margin: 28px 0 0;
        color: var(--muted);
        font-size: clamp(1.08rem, 2vw, 1.55rem);
        line-height: 1.35;
      }

      .button-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; }
      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 16px;
        border: 2px solid var(--white);
        background: transparent;
        color: var(--white);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.75rem;
        font-weight: 900;
      }
      .button:hover, .button.primary { background: var(--white); color: var(--black); }
      .button.primary:hover { background: var(--clay); border-color: var(--clay); color: var(--black); }

      .section {
        padding: 70px 0;
        border-bottom: 2px solid var(--white);
      }

      .section-grid {
        display: grid;
        grid-template-columns: 0.32fr 0.68fr;
        gap: 34px;
      }

      .label {
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.72rem;
        font-weight: 900;
      }

      .lead {
        color: var(--muted);
        font-size: clamp(1.05rem, 1.8vw, 1.34rem);
        line-height: 1.55;
      }

      .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

      .card {
        border: 2px solid var(--white);
        padding: 20px;
        min-height: 230px;
        background: rgba(245, 241, 232, 0.03);
      }

      .card.light {
        background: var(--paper);
        color: var(--black);
        border-color: var(--paper);
      }

      .card .meta, .meta {
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 900;
        margin-bottom: 12px;
      }

      .card p { color: var(--muted); margin-bottom: 0; }
      .card.light p { color: var(--muted-dark); }

      .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px; }
      .tag { border: 1px solid currentColor; padding: 5px 7px; color: var(--clay); text-transform: uppercase; letter-spacing: .08em; font-size: .64rem; font-weight: 900; }

      .table-list { border-top: 2px solid var(--white); }
      .row {
        display: grid;
        grid-template-columns: 0.7fr 1.1fr 0.8fr 0.8fr;
        gap: 18px;
        padding: 18px 0;
        border-bottom: 2px solid var(--white);
        align-items: baseline;
      }
      .row strong { font-size: 1.05rem; text-transform: uppercase; }
      .row span { color: var(--muted); }

      .visual-block {
        min-height: 340px;
        border: 2px solid var(--white);
        background:
          linear-gradient(135deg, transparent 0 46%, var(--white) 46% 47%, transparent 47%),
          radial-gradient(circle at 22% 22%, rgba(183,139,96,.9), transparent 20%),
          linear-gradient(135deg, #111, #050505 55%, #2b1c12);
        position: relative;
        overflow: hidden;
      }

      .visual-block::after {
        content: attr(data-title);
        position: absolute;
        left: 16px;
        bottom: 14px;
        right: 16px;
        color: var(--white);
        font-family: Arial Black, Arial, sans-serif;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: .8;
        text-transform: uppercase;
        letter-spacing: -.08em;
      }

      .quote-box {
        border-left: 10px solid var(--clay);
        padding: 18px 0 18px 22px;
        color: var(--muted);
        font-size: clamp(1.1rem, 2vw, 1.5rem);
      }

      .site-footer {
        width: min(var(--max), calc(100% - 24px));
        margin: 0 auto;
        padding: 28px 0 44px;
        color: var(--muted);
        display: flex;
        justify-content: space-between;
        gap: 20px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        font-weight: 800;
      }

      .print-page {
        background: var(--paper);
        color: var(--black);
        min-height: 100vh;
        padding: 48px;
      }
      .print-page h1, .print-page h2, .print-page h3 { color: var(--black); }
      .print-page p { color: rgba(5,5,5,.74); }

      @media print {
        .site-header, .site-footer, .button-row, .no-print { display: none !important; }
        body { background: white; color: black; }
        .print-page { padding: 0; background: white; color: black; }
      }

      @media (max-width: 900px) {
        .nav { align-items: flex-start; padding: 14px 0; flex-direction: column; }
        .nav-links { justify-content: flex-start; }
        .section-grid, .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; }
        .row { grid-template-columns: 1fr; gap: 6px; }
        .page-hero { min-height: auto; padding: 60px 0 42px; }
      }
    </style>
  </head>
  <body>
    <div class='site-shell'>
      <header class='site-header'>
        <nav class='nav' aria-label='Main navigation'>
          <a class='brand' href='/'>Guillermo<br /><small>{eyebrow}</small></a>
          <div class='nav-links'>
            {nav.map(([href, label]) => <a href={href}>{label}</a>)}
          </div>
        </nav>
      </header>
      <slot />
      <footer class='site-footer'>
        <span>© 2026 Guillermo Laporta</span>
        <span>Music / Image / Space</span>
      </footer>
    </div>
  </body>
</html>

---
const {
  title = 'Guillermo Laporta',
  description = 'Guillermo Laporta is a flutist, composer, designer and multimedia artist based between New York City and Asturias.',
  eyebrow = 'Flutist / Composer / Designer'
} = Astro.props;

const nav = [
  { href: '/', label: 'Home', icon: '⌂' },
  { href: '/calendar/', label: 'Calendar', icon: '◷' },
  { href: '/portfolio/', label: 'Portfolio', icon: '▧' },
  { href: '/catalogue/', label: 'Catalogue', icon: '♪' },
  { href: '/discography/', label: 'Discography', icon: '◉' },
  { href: '/images/', label: 'Images', icon: '□' },
  { href: '/bio/', label: 'Bio', icon: 'i' },
  { href: '/contact/', label: 'Contact', icon: '✉' }
];

const tabNav = nav.filter((item) => ['/', '/calendar/', '/portfolio/', '/catalogue/', '/contact/'].includes(item.href));
const currentPath = Astro.url.pathname;
const isActive = (href) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---
<!DOCTYPE html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <meta name='description' content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        --black: #050505;
        --white: #f5f1e8;
        --paper: #eee7dc;
        --brown: #8a5f37;
        --brown-dark: #342315;
        --clay: #b78b60;
        --ink: #111111;
        --muted: rgba(245, 241, 232, 0.66);
        --muted-dark: rgba(5, 5, 5, 0.62);
        --line: rgba(245, 241, 232, 0.16);
        --line-strong: rgba(245, 241, 232, 0.34);
        --line-dark: rgba(5, 5, 5, 0.14);
        --glass: rgba(12, 12, 12, 0.72);
        --glass-light: rgba(245, 241, 232, 0.08);
        --max: 1240px;
        --radius: 28px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background: var(--black);
        color: var(--white);
        font-family: Arial, Helvetica, sans-serif;
        text-rendering: geometricPrecision;
        -webkit-font-smoothing: antialiased;
      }

      a { color: inherit; text-decoration: none; }
      p { line-height: 1.6; }
      code { color: var(--clay); }

      .site-shell {
        min-height: 100svh;
        padding-bottom: 0;
        background:
          radial-gradient(circle at 12% 0%, rgba(183,139,96,.18), transparent 28rem),
          linear-gradient(90deg, rgba(245,241,232,.028) 1px, transparent 1px),
          linear-gradient(180deg, rgba(245,241,232,.028) 1px, transparent 1px),
          var(--black);
        background-size: auto, 72px 72px, 72px 72px, auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: linear-gradient(180deg, rgba(5,5,5,.92), rgba(5,5,5,.72));
        backdrop-filter: blur(22px) saturate(1.4);
        -webkit-backdrop-filter: blur(22px) saturate(1.4);
        border-bottom: 1px solid rgba(245,241,232,.1);
      }

      .app-nav {
        width: min(var(--max), calc(100% - 20px));
        margin: 0 auto;
        padding: 12px 0 10px;
      }

      .app-top-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 10px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 14px;
        background: var(--paper);
        color: var(--black);
        font-family: Arial Black, Arial, sans-serif;
        font-size: 1.25rem;
        letter-spacing: -0.12em;
      }

      .brand-copy {
        display: grid;
        gap: 2px;
        min-width: 0;
      }

      .brand-name {
        font-family: Arial Black, Arial, Helvetica, sans-serif;
        text-transform: uppercase;
        letter-spacing: -0.065em;
        font-size: clamp(1.1rem, 2.2vw, 1.55rem);
        line-height: .88;
        white-space: nowrap;
      }

      .brand-subtitle {
        color: var(--clay);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-size: 0.58rem;
        font-weight: 900;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .app-status-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 0 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(245,241,232,.065);
        color: var(--muted);
        font-size: 0.72rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
      }

      .app-status-pill::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--clay);
        box-shadow: 0 0 18px rgba(183,139,96,.9);
      }

      .nav-chip-scroll {
        display: flex;
        gap: 8px;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding: 2px 0 4px;
        scrollbar-width: none;
      }

      .nav-chip-scroll::-webkit-scrollbar { display: none; }

      .nav-chip {
        flex: 0 0 auto;
        scroll-snap-align: start;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 40px;
        padding: 0 14px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(245,241,232,.055);
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.075em;
        font-size: 0.68rem;
        font-weight: 900;
        transition: background .18s ease, color .18s ease, border-color .18s ease, transform .18s ease;
      }

      .nav-chip:hover {
        transform: translateY(-1px);
        color: var(--white);
        border-color: var(--line-strong);
        background: rgba(245,241,232,.1);
      }

      .nav-chip.is-active {
        background: var(--paper);
        border-color: var(--paper);
        color: var(--black);
      }

      .nav-chip-icon {
        width: 21px;
        height: 21px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        background: rgba(5,5,5,.14);
        font-size: 0.72rem;
        line-height: 1;
      }

      .nav-chip.is-active .nav-chip-icon {
        background: rgba(5,5,5,.12);
      }

      .mobile-tabbar {
        display: none;
      }

      .page {
        width: min(var(--max), calc(100% - 24px));
        margin: 0 auto;
      }

      .page-hero {
        min-height: 58svh;
        padding: 82px 0 54px;
        display: grid;
        align-items: end;
        border-bottom: 1px solid var(--line-strong);
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.72rem;
        font-weight: 900;
      }

      .eyebrow::before { content: ''; width: 42px; height: 2px; background: var(--clay); }

      h1, h2, h3 {
        margin: 0;
        font-family: Arial Black, Arial, Helvetica, sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.085em;
      }

      h1 {
        max-width: 1100px;
        font-size: clamp(4.2rem, 15vw, 14rem);
        line-height: 0.72;
      }

      h2 {
        font-size: clamp(2.8rem, 8vw, 7.5rem);
        line-height: 0.78;
      }

      h3 {
        font-size: clamp(1.8rem, 4vw, 3.7rem);
        line-height: 0.82;
      }

      .intro {
        max-width: 820px;
        margin: 28px 0 0;
        color: var(--muted);
        font-size: clamp(1.08rem, 2vw, 1.55rem);
        line-height: 1.35;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 28px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 16px;
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        background: rgba(245,241,232,.06);
        color: var(--white);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.75rem;
        font-weight: 900;
      }

      .button:hover, .button.primary {
        background: var(--white);
        color: var(--black);
        border-color: var(--white);
      }

      .button.primary:hover { background: var(--clay); border-color: var(--clay); color: var(--black); }

      .section {
        padding: 70px 0;
        border-bottom: 1px solid var(--line-strong);
      }

      .section-grid {
        display: grid;
        grid-template-columns: 0.32fr 0.68fr;
        gap: 34px;
      }

      .label {
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 0.72rem;
        font-weight: 900;
      }

      .lead {
        color: var(--muted);
        font-size: clamp(1.05rem, 1.8vw, 1.34rem);
        line-height: 1.55;
      }

      .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
      .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

      .card {
        border: 1px solid var(--line-strong);
        border-radius: 24px;
        padding: 20px;
        min-height: 230px;
        background: rgba(245, 241, 232, 0.04);
        box-shadow: inset 0 1px 0 rgba(245,241,232,.08);
      }

      .card.light {
        background: var(--paper);
        color: var(--black);
        border-color: var(--paper);
      }

      .card .meta, .meta {
        color: var(--clay);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
        font-weight: 900;
        margin-bottom: 12px;
      }

      .card p { color: var(--muted); margin-bottom: 0; }
      .card.light p { color: var(--muted-dark); }

      .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px; }
      .tag { border: 1px solid currentColor; border-radius:999px; padding: 5px 8px; color: var(--clay); text-transform: uppercase; letter-spacing: .08em; font-size: .64rem; font-weight: 900; }

      .table-list { border-top: 1px solid var(--line-strong); }
      .row {
        display: grid;
        grid-template-columns: 0.7fr 1.1fr 0.8fr 0.8fr;
        gap: 18px;
        padding: 18px 0;
        border-bottom: 1px solid var(--line-strong);
        align-items: baseline;
      }
      .row strong { font-size: 1.05rem; text-transform: uppercase; }
      .row span { color: var(--muted); }

      .visual-block {
        min-height: 340px;
        border: 1px solid var(--line-strong);
        border-radius: 28px;
        background:
          linear-gradient(135deg, transparent 0 46%, var(--white) 46% 47%, transparent 47%),
          radial-gradient(circle at 22% 22%, rgba(183,139,96,.9), transparent 20%),
          linear-gradient(135deg, #111, #050505 55%, #2b1c12);
        position: relative;
        overflow: hidden;
      }

      .visual-block::after {
        content: attr(data-title);
        position: absolute;
        left: 16px;
        bottom: 14px;
        right: 16px;
        color: var(--white);
        font-family: Arial Black, Arial, sans-serif;
        font-size: clamp(2rem, 5vw, 4rem);
        line-height: .8;
        text-transform: uppercase;
        letter-spacing: -.08em;
      }

      .quote-box {
        border-left: 10px solid var(--clay);
        padding: 18px 0 18px 22px;
        color: var(--muted);
        font-size: clamp(1.1rem, 2vw, 1.5rem);
      }

      .site-footer {
        width: min(var(--max), calc(100% - 24px));
        margin: 0 auto;
        padding: 28px 0 44px;
        color: var(--muted);
        display: flex;
        justify-content: space-between;
        gap: 20px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        font-weight: 800;
      }

      .print-page {
        background: var(--paper);
        color: var(--black);
        min-height: 100vh;
        padding: 48px;
      }
      .print-page h1, .print-page h2, .print-page h3 { color: var(--black); }
      .print-page p { color: rgba(5,5,5,.74); }

      @media print {
        .site-header, .site-footer, .button-row, .no-print, .mobile-tabbar { display: none !important; }
        body { background: white; color: black; }
        .print-page { padding: 0; background: white; color: black; }
      }

      @media (max-width: 900px) {
        .site-shell { padding-bottom: 98px; }
        .app-status-pill { display: none; }
        .app-nav { width: calc(100% - 20px); padding: 10px 0 8px; }
        .brand-mark { width: 38px; height: 38px; border-radius: 13px; }
        .brand-name { font-size: 1.08rem; }
        .brand-subtitle { max-width: 210px; }
        .nav-chip-scroll { margin-right: -10px; padding-right: 10px; }
        .nav-chip { min-height: 38px; padding: 0 12px; font-size: .64rem; }

        .mobile-tabbar {
          position: fixed;
          left: 10px;
          right: 10px;
          bottom: 10px;
          z-index: 60;
          display: grid;
          grid-template-columns: repeat(5, 1fr);
          gap: 6px;
          padding: 8px;
          border: 1px solid rgba(245,241,232,.18);
          border-radius: 28px;
          background: rgba(12,12,12,.78);
          backdrop-filter: blur(22px) saturate(1.35);
          -webkit-backdrop-filter: blur(22px) saturate(1.35);
          box-shadow: 0 18px 60px rgba(0,0,0,.55);
        }

        .mobile-tab {
          min-width: 0;
          min-height: 54px;
          display: grid;
          place-items: center;
          gap: 2px;
          padding: 5px 4px;
          border-radius: 21px;
          color: rgba(245,241,232,.62);
          font-size: .58rem;
          font-weight: 900;
          letter-spacing: .02em;
          text-transform: uppercase;
        }

        .mobile-tab-icon {
          width: 24px;
          height: 24px;
          display: grid;
          place-items: center;
          font-size: .95rem;
          line-height: 1;
        }

        .mobile-tab.is-active {
          color: var(--black);
          background: var(--paper);
        }

        .section-grid { grid-template-columns: 1fr; }
        .row { grid-template-columns: 1fr; gap: 6px; }
        .page-hero { min-height: auto; padding: 54px 0 40px; }
        .section { padding: 54px 0; }

        .grid-2,
        .grid-3,
        .grid-4 {
          display: flex;
          gap: 12px;
          overflow-x: auto;
          scroll-snap-type: x mandatory;
          -webkit-overflow-scrolling: touch;
          margin-right: -12px;
          padding-right: 12px;
          padding-bottom: 8px;
          scrollbar-width: none;
        }

        .grid-2::-webkit-scrollbar,
        .grid-3::-webkit-scrollbar,
        .grid-4::-webkit-scrollbar { display: none; }

        .grid-2 > *,
        .grid-3 > *,
        .grid-4 > * {
          flex: 0 0 min(84vw, 390px);
          scroll-snap-align: start;
        }

        .grid-3 > article,
        .grid-4 > article { min-width: min(84vw, 390px); }
      }
    </style>
  </head>
  <body>
    <div class='site-shell'>
      <header class='site-header'>
        <nav class='app-nav' aria-label='Main navigation'>
          <div class='app-top-row'>
            <a class='brand' href='/'>
              <span class='brand-mark'>GL</span>
              <span class='brand-copy'>
                <span class='brand-name'>Guillermo Laporta</span>
                <span class='brand-subtitle'>{eyebrow}</span>
              </span>
            </a>
            <span class='app-status-pill'>Personal archive</span>
          </div>
          <div class='nav-chip-scroll' aria-label='Section shortcuts'>
            {nav.map((item) => (
              <a class={`nav-chip ${isActive(item.href) ? 'is-active' : ''}`} href={item.href}>
                <span class='nav-chip-icon'>{item.icon}</span>
                <span>{item.label}</span>
              </a>
            ))}
          </div>
        </nav>
      </header>

      <slot />

      <nav class='mobile-tabbar' aria-label='Mobile primary navigation'>
        {tabNav.map((item) => (
          <a class={`mobile-tab ${isActive(item.href) ? 'is-active' : ''}`} href={item.href}>
            <span class='mobile-tab-icon'>{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <footer class='site-footer'>
        <span>© 2026 Guillermo Laporta</span>
        <span>Music / Image / Space</span>
      </footer>
    </div>
  </body>
</html>

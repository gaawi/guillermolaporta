---
import AppLayout from '../layouts/AppLayout.astro';
import { bio } from '../data/site.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';
---
<AppLayout title="Bio — Guillermo Laporta" description="Biography, leadership and practice of flutist, composer and cultural producer Guillermo Laporta.">
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">07 — About</div>
    <h1 class="subpage-title">Flutist, composer <em>&</em> producer.</h1>
    <p class="subpage-sub">Biography, leadership and press materials. Program bios, CV and photos available for download below.</p>
  </div>

  <!-- Leadership first, as requested -->
  <section class="section" style="padding-top:0;max-width:1480px;margin:0 auto">
    <div class="section-head" style="margin-bottom:36px">
      <div class="lhs">
        <div class="section-num">Leadership</div>
        <h2 class="section-title" style="font-size:clamp(32px,4vw,56px)">Building <em>organisations</em>.</h2>
      </div>
    </div>
    <div class="leadership-grid">
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">CreArtBox</div>
          <div class="lead-period">New York · 2013 – present</div>
          <div class="lead-role">Co-founder & Executive Director</div>
        </div>
        <div class="lead-body">
          Chamber music and multimedia performing arts organization. 20+ professional artists, 20+ performances per season at The DiMenna Center, Mark Morris Center, The William Vale, Greenwich House and more. Sustained support from NYSCA. Covered by The New Yorker, Broadway World, Time Out.
        </div>
        <a class="lead-link" href="https://creartbox.nyc" target="_blank" rel="noopener">creartbox.nyc ↗</a>
      </div>
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">Festival ADAR</div>
          <div class="lead-period">Asturias · 2020 – present</div>
          <div class="lead-role">Founder & Artistic Director</div>
        </div>
        <div class="lead-body">
          Itinerant festival bringing world-class chamber music, composer commissions and visual installations to underserved rural communities in Asturias, Spain. Supported by the Government of Asturias with €120,000 across four awards (2021–25).
        </div>
        <a class="lead-link" href="https://festivaladar.com" target="_blank" rel="noopener">festivaladar.com ↗</a>
      </div>
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">CreArt Music Series</div>
          <div class="lead-period">New York · 2008 – 2013</div>
          <div class="lead-role">Founder & Artistic Director</div>
        </div>
        <div class="lead-body">
          Annual chamber music series at the Kosciuszko Foundation presenting 25+ concerts with international soloists and emerging composers. Predecessor to the CreArtBox nonprofit.
        </div>
      </div>
    </div>
  </section>

  <!-- Bio strips -->
  <section class="section" style="max-width:1480px;margin:0 auto">
    <div class="biostrip">
      <div class="biostrip-text">
        <h3>Flutist, composer <em>&</em> cultural producer.</h3>
        <p>{bio.short}</p>
        <div class="bio-stats">
          <div class="stat"><div class="num">13<em>+</em></div><div class="lbl">Years NYC</div></div>
          <div class="stat"><div class="num">55<em>+</em></div><div class="lbl">Productions</div></div>
          <div class="stat"><div class="num">2</div><div class="lbl">Companies</div></div>
          <div class="stat"><div class="num"><em>€</em>120k</div><div class="lbl">EU Grants</div></div>
        </div>
      </div>
      <div class="bio-side">
        <div class="bio-card dark">
          <div class="lbl">Based</div>
          <div class="val">New York · <em>Asturias</em></div>
          <div class="desc">Between New York City and Spain since 2012.</div>
        </div>
        <div class="bio-card">
          <div class="lbl">Current status</div>
          <div class="val">NYC · <em>Composing</em></div>
          <div class="desc">Working on the 2026–27 season programmes.</div>
        </div>
        <div class="bio-card">
          <div class="lbl">Education</div>
          <div class="val">RCM London · <em>Musikene</em></div>
          <div class="desc">M.Mus. Advanced Performance (Jaime Martín, Paul Edmund Davies). M.A. Arts Management.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Long bio -->
  <section class="section" style="max-width:1480px;margin:0 auto;padding-top:48px">
    <div class="section-head" style="margin-bottom:36px">
      <div class="lhs">
        <div class="section-num">Long bio</div>
        <h2 class="section-title" style="font-size:clamp(28px,3vw,44px)">Full <em>biography</em>.</h2>
      </div>
    </div>
    <div style="max-width:72ch">
      {bio.long.map((para) => (
        <p style="font-size:17px;line-height:1.7;color:var(--ink-2);font-weight:350;margin-bottom:18px">{para}</p>
      ))}
    </div>
  </section>

  <!-- Press kit -->
  <section class="section" style="max-width:1480px;margin:0 auto;padding-top:48px;padding-bottom:96px">
    <div class="section-head" style="margin-bottom:36px">
      <div class="lhs">
        <div class="section-num">Press kit</div>
        <h2 class="section-title" style="font-size:clamp(28px,3vw,44px)">Photos &amp; <em>materials</em>.</h2>
      </div>
    </div>
    <p style="font-size:15px;color:var(--ink-2);margin-bottom:28px">Press photos, CV and bio available for download.</p>
    <div style="display:flex;flex-wrap:wrap;gap:12px">
      <a class="btn primary" href={`${b}downloads/guillermo-laporta-cv.pdf`} target="_blank">CV — PDF ↗</a>
      <a class="btn" href={`${b}downloads/laporta-press-photo-1.jpg`} target="_blank">Press photo 1</a>
      <a class="btn" href={`${b}downloads/laporta-press-photo-2.jpg`} target="_blank">Press photo 2</a>
      <a class="btn" href="mailto:guillermo@creartbox.nyc">Press enquiries</a>
    </div>
  </section>
</AppLayout>

---
const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${b}`} />
    <link rel="canonical" href={b} />
    <title>Redirecting…</title>
  </head>
  <body></body>
</html>

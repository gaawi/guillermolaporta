---
import AppLayout from '../layouts/AppLayout.astro';
import { bio, albums, liveRecordings } from '../data/site.js';
import { projects as creativeWorks } from '../data/projects.js';

const bioMedium = bio.long.slice(0, 3);

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';

const designCredits = [
  { title: 'As One', year: '2018', role: 'Lighting and set design', venue: 'Opera by Laura Kaminsky. 14th Street Y Theater, NYC.' },
  { title: '8 Million Protagonists', year: '2014', role: 'Lighting and set design', venue: 'Multimedia production. Here Arts Center, NYC.' },
  { title: 'Pedro Pan', year: '2016, 2018', role: 'Lighting and set design', venue: 'Musical. The Chain Theater, NYC and Toronto Playhouse.' },
  { title: 'Painted Alice', year: '2019', role: 'Lighting design', venue: 'Theater. Robert Moss Theater, NYC.' },
];

const mentors = [
  { name: 'Jaime Martín', desc: 'Chief Conductor, Melbourne Symphony Orchestra & Los Angeles Chamber Orchestra' },
  { name: 'Sue Thomas', desc: 'Principal Flute, London Philharmonic' },
  { name: 'Paul Edmund Davies', desc: 'Principal Flute, London Symphony' },
  { name: 'Miguel Ángel Angulo', desc: 'Principal Flute, Spanish National Orchestra' },
];

const awards = [
  'New York State Council on the Arts (NYSCA)',
  'National Endowment for the Arts (NEA)',
  'NYC Department of Cultural Affairs',
  'Flushing Town Hall',
  'Queens Council on the Arts',
  'New York Foundation for the Arts',
  'The Amphion Foundation',
  'The Alice M. Ditson Fund',
  'Aaron Copland Fund for Music',
  'Government of the Principality of Asturias (€120,000 · 2021–25)',
  'City Artist Corps',
  'Promete Foundation Talent Award',
  'Caja Madrid Foundation',
  'Ibercaja Foundation',
  'Montehermoso Creation Award',
  'Avaloch Music Institute',
  'SMA Chamber Music Competition',
];

const pressQuotes = [
  { quote: 'Art and music top picks.', source: 'The New Yorker' },
  { quote: 'A new ensemble devoted to multidisciplinary events designed by flutist.', source: 'Time Out' },
  { quote: 'A shocking staging.', source: 'El País' },
  { quote: 'You should check out this amazing presentation of Awave.', source: 'Times Ledger' },
  { quote: 'Impeccable sound design by Guillermo Laporta.', source: 'Mozvr' },
  { quote: 'Guillermo Laporta knows how to design for a festival.', source: 'Theasy' },
  { quote: 'An explosion of rhythm, color and sensitivity.', source: 'El Diario del Alto Aragón' },
  { quote: 'Directed by Guillermo Laporta and Josefina Urraca, the remarkable production fuses art forms to create a wholly authentic, visually and aurally compelling experience.', source: 'Broadway World' },
  { quote: 'A full scale set design and a unique visual approach.', source: 'I Care if You Listen' },
];

const catalogueSections = [
  {
    heading: 'Chamber Music — Original Compositions',
    items: [
      { title: 'Suite AWAVE', forces: 'Flute, piano, and electronics' },
      { title: 'Piano Trio "Craziest Thing"', forces: 'Violin, cello, and piano' },
      { title: 'Twelve Preludes', forces: 'Flute and piano' },
      { title: 'Traveling', forces: 'Solo piano' },
      { title: 'Balance', forces: 'Solo piano' },
      { title: 'Ballet', forces: 'Solo piano' },
    ],
  },
  {
    heading: 'Opera and Ballet',
    items: [
      { title: 'Architecture of a Common Man', forces: 'Chamber opera — libretto and score' },
      { title: 'Two Roads', forces: 'Ballet — libretto and score' },
    ],
  },
  {
    heading: 'Electroacoustic Works',
    items: [
      { title: 'Queens Log', forces: 'Solo flute + field recordings' },
      { title: 'Música de Cristal', forces: 'Flute, electronics, and amplified glass installation' },
      { title: 'Harte Rate', forces: 'Flute and electronics' },
      { title: 'Progress > Defiance', forces: 'Live flute and electronics' },
    ],
  },
  {
    heading: 'Arrangements — Chamber Ensemble / Piano Quintet with Flute',
    items: [
      { title: 'Modest Mussorgsky — Pictures at an Exhibition', forces: 'Piano quintet with flute' },
      { title: 'Igor Stravinsky — Petrushka', forces: 'Chamber ensemble with flute' },
      { title: 'Manuel de Falla — Siete canciones populares españolas', forces: 'Flute + ensemble' },
      { title: 'Frank Martin — Ballade', forces: 'Flute + chamber ensemble' },
      { title: 'György Ligeti — Musica Ricercata', forces: 'Chamber arrangement' },
      { title: 'Antonín Dvořák — American String Quartet, Op. 96', forces: 'Chamber ensemble with flute' },
      { title: 'Antonín Dvořák — Piano Quintet No. 2, Op. 81', forces: 'Flute + piano quartet' },
    ],
  },
  {
    heading: 'Arrangements — Flute & Piano',
    items: [
      { title: 'Claude Debussy — Violin Sonata', forces: 'Flute and piano' },
      { title: 'Ottorino Respighi — Violin Sonata in B minor', forces: 'Flute and piano' },
      { title: 'Leoš Janáček — Violin Sonata', forces: 'Flute and piano' },
    ],
  },
];
---
<AppLayout
  title="Bio & Resume — Guillermo Laporta"
  description="Biography, compositions, recordings, education and grants — Guillermo Laporta."
>
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">Bio & Resume</div>
    <h1 class="subpage-title">Bio <em>&amp;</em> resume.</h1>
    <p class="subpage-sub">Flutist · Composer · Cultural Producer · Executive Director of CreArtBox and Festival ADAR</p>
  </div>

  <!-- ── BIO SWITCHER ───────────────────────────────────────────── -->
  <section class="section bio-sw-section">
    <div class="bio-sw-head">
      <div class="bio-sw-tabs" id="bioTabs">
        <button class="bio-sw-tab active" data-bio="short">Short</button>
        <button class="bio-sw-tab" data-bio="medium">Medium</button>
        <button class="bio-sw-tab" data-bio="long">Long</button>
      </div>
      <div class="bio-sw-actions">
        <button class="btn bio-copy-btn" id="bioCopy">Copy text</button>
        <a class="btn primary" href={`${b}downloads/guillermo-laporta-cv.pdf`} target="_blank">CV — PDF ↗</a>
      </div>
    </div>

    <div class="bio-panel" id="bio-short">
      <p class="bio-p">{bio.short}</p>
    </div>
    <div class="bio-panel bio-hidden" id="bio-medium">
      {bioMedium.map((para) => <p class="bio-p">{para}</p>)}
    </div>
    <div class="bio-panel bio-hidden" id="bio-long">
      {bio.long.map((para) => <p class="bio-p">{para}</p>)}
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll('.bio-sw-tab');
    const panels = document.querySelectorAll('.bio-panel');
    const copyBtn = document.getElementById('bioCopy');
    let current = 'short';

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById('bio-' + current).classList.add('bio-hidden');
        current = tab.dataset.bio;
        document.getElementById('bio-' + current).classList.remove('bio-hidden');
      });
    });

    copyBtn.addEventListener('click', () => {
      const text = document.getElementById('bio-' + current).innerText.trim();
      navigator.clipboard.writeText(text).then(() => {
        copyBtn.textContent = 'Copied!';
        setTimeout(() => copyBtn.textContent = 'Copy text', 2000);
      });
    });
  </script>

  <!-- ── CV HEADING ───────────────────────────────────────────────── -->
  <div class="cv-page-head">
    <div class="cv-page-kicker">Curriculum Vitae</div>
    <h2 class="cv-page-title">Experience <em>&amp; work</em>.</h2>
  </div>

  <!-- ── LEADERSHIP ─────────────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Leadership</div>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">CreArtBox</div>
          <div class="cv-entry-date">New York, NY · 2013 – present</div>
        </div>
        <div class="cv-entry-role">Executive Director · Co-Founder & Co-Artistic Director</div>
        <p class="cv-entry-body">Chamber music organization co-founded with pianist Josefina Urraca. Programs an annual season of original productions combining live performance with theatrical design, projection and dance — alongside concerts and touring. Venues include The DiMenna Center, Mark Morris Center, The William Vale and New York Society for Ethical Culture. Supported by NYSCA; recognized by The New Yorker, Broadway World and Time Out. Grew from Cre.Art Project, founded in Spain in 2006.</p>
        <a class="cv-entry-link" href="https://creartbox.nyc" target="_blank" rel="noopener">creartbox.nyc ↗</a>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Festival ADAR</div>
          <div class="cv-entry-date">Asturias, Spain · 2020 – present</div>
        </div>
        <div class="cv-entry-role">Executive Director · Co-Founder & Co-Artistic Director</div>
        <p class="cv-entry-body">Annual itinerant festival presenting chamber music, new commissions and site-specific art in rural Asturias — in village chapels, historic palaces and open landscapes rarely used as performance spaces. Founded 2020 in Leiguarda, Belmonte de Miranda. Supported by the Government of the Principality of Asturias.</p>
        <a class="cv-entry-link" href="https://festivaladar.com" target="_blank" rel="noopener">festivaladar.com ↗</a>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">St. John's Preparatory School</div>
          <div class="cv-entry-date">New York, NY · 2016 – 2017</div>
        </div>
        <div class="cv-entry-role">Co-Director of Performing Arts Program</div>
        <p class="cv-entry-body">Proposed and developed the school's Performing Arts Department from the ground up. Redesigned spaces to create dedicated studios — a live stage, a photo and video studio and a multimedia production room. Created curriculum and taught multimedia design, photography and video, performing arts and production.</p>
      </div>
    </div>
  </section>

  <!-- ── FESTIVALS & SERIES ─────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Festivals &amp; Series</div>
    <div class="cv-entries">
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">CreArt Music Series</div>
          <div class="cv-entry-date">Manhattan · 2008 – 2013</div>
        </div>
        <div class="cv-entry-role">Founder & Artistic Director</div>
        <p class="cv-entry-body">Annual concert series at the Kosciuszko Foundation presenting chamber music with international soloists and emerging composers. 25+ concerts over six seasons.</p>
      </div>
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Aspect Chamber Music Series</div>
          <div class="cv-entry-date">New York, NY · 2020 – 2025</div>
        </div>
        <div class="cv-entry-role">Associate Producer</div>
        <p class="cv-entry-body">"Music in Context" — refined programming with talks by world-renowned speakers and musicians.</p>
      </div>
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">CreArt Music Festival</div>
          <div class="cv-entry-date">Queens, NY · 2018</div>
        </div>
        <div class="cv-entry-role">Director</div>
      </div>
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">PlayLoud Music Festival</div>
          <div class="cv-entry-date">NYC</div>
        </div>
        <div class="cv-entry-role">Director · Instituto Cervantes, New York</div>
      </div>
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Jazz in Blue Festival</div>
        </div>
        <div class="cv-entry-role">Director · With EMI Music</div>
      </div>
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">10×10 Music Festival</div>
          <div class="cv-entry-date">Zaragoza, Spain</div>
        </div>
        <div class="cv-entry-role">Director</div>
      </div>
    </div>
  </section>

  <!-- ── CREATIVE WORKS ─────────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Creative Works</div>
    <div class="cv-entries">
      {creativeWorks.map((w) => (
        <div class="cv-entry cv-entry-compact">
          <div class="cv-entry-head">
            <div class="cv-entry-title">{w.title}</div>
            <div class="cv-entry-date">{w.year}</div>
          </div>
          <div class="cv-entry-role">{w.roles}</div>
          <p class="cv-entry-body">{w.desc}</p>
          {w.url && <a class="cv-entry-link" href={w.url} target="_blank" rel="noopener">Project page ↗</a>}
        </div>
      ))}
    </div>
  </section>

  <!-- ── PERFORMANCE CAREER ─────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Performance</div>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Flutist</div>
        </div>
        <ul class="cv-list" style="margin-bottom:16px">
          <li>Co-Principal Flute · Oviedo Filarmonía Orchestra · 2009–12</li>
          <li>Principal Flute · Herald Chamber Orchestra · 2012–15</li>
          <li>Principal Flute · New York International Chamber Orchestra · 2013–18</li>
          <li>BBC Orchestra</li>
          <li>Orquesta del Principado de Asturias</li>
          <li>Le Train Bleu Ensemble</li>
          <li>Orquesta Sinfónica de Euskadi</li>
        </ul>
        <p class="cv-entry-body">Shared the stage with Sir Roger Norrington, Andrew Litton, Pablo González, Vladimir Ashkenazy, Truls Mørk, Natalia Gutman, the Labèque sisters, Ainhoa Arteta, Jiri Barta and Heinrich Schiff. Carnegie Hall and Lincoln Center. Recorded for Warner Music, EMI and Naxos.</p>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Repertoire Development</div>
        </div>
        <p class="cv-entry-body">Deeply committed to expanding the flute repertoire in chamber music — through original compositions and transcriptions of pieces written for other instruments. Three studio albums released: Debussy & Respighi Violin Sonatas: Transcriptions for Flute and Piano (2019); Awave: Original Compositions for Flute, Piano, Electronics & Video (2020); 12 Preludes for Flute (2020). Available on Spotify, Apple Music, and YouTube Music.</p>
      </div>
    </div>
  </section>

  <!-- ── DESIGN & MULTIMEDIA ────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Design &amp; Multimedia</div>
    <div class="cv-entries">
      {designCredits.map((d) => (
        <div class="cv-entry cv-entry-compact">
          <div class="cv-entry-head">
            <div class="cv-entry-title">{d.title}</div>
            <div class="cv-entry-date">{d.year}</div>
          </div>
          <div class="cv-entry-role">{d.role}</div>
          <p class="cv-entry-body">{d.venue}</p>
        </div>
      ))}
      <div class="cv-entry cv-entry-compact">
        <div class="cv-entry-head">
          <div class="cv-entry-title">VR Sound Design & Composition</div>
        </div>
        <p class="cv-entry-body">Inspirit · Puzzle Rain · The Dreamsons · Alice · Letris · Blupt! (with Mozilla) · Unboring · Barrabes Internet · Ivanovich Games.</p>
      </div>
    </div>
  </section>

  <!-- ── EDUCATION ──────────────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Education</div>
    <div class="cv-entries">
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">M.Mus. Advanced Performance — Flute</div>
          <div class="cv-entry-date">London, 2010</div>
        </div>
        <div class="cv-entry-role">Royal College of Music</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">B.Mus. Music Performance — Flute</div>
          <div class="cv-entry-date">London, 2008</div>
        </div>
        <div class="cv-entry-role">Royal College of Music</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">M.A. Arts Management</div>
          <div class="cv-entry-date">Madrid, 2009</div>
        </div>
        <div class="cv-entry-role">University of Alcalá de Henares</div>
      </div>
      <div class="cv-entry">
        <div class="cv-entry-head">
          <div class="cv-entry-title">Superior Degree in Music — Flute</div>
          <div class="cv-entry-date">San Sebastián</div>
        </div>
        <div class="cv-entry-role">Musikene — Superior Conservatory of Music of the Basque Country</div>
      </div>
      <div class="cv-entry" style="padding-bottom:20px">
        <div class="cv-entry-role" style="margin-bottom:14px">Notable Mentors</div>
        <div class="mentors-grid">
          {mentors.map((m) => (
            <div class="mentor-card">
              <div class="mentor-name">{m.name}</div>
              <div class="mentor-desc">{m.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── DISCOGRAPHY ────────────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Recordings</div>
    <div class="cv-entries">
      <div class="cv-sublabel">Solo Albums</div>
      {albums.map((album) => (
        <div class="cv-entry cv-entry-compact">
          <div class="cv-entry-head">
            <div class="cv-entry-title">{album.title}</div>
            <div class="cv-entry-date">{album.year}</div>
          </div>
          <div class="cv-entry-role">{album.format}</div>
          {album.description && <p class="cv-entry-body">{album.description}</p>}
        </div>
      ))}
      <div class="cv-sublabel" style="margin-top:32px">With CreArtBox (selected)</div>
      {liveRecordings.map((r) => (
        <div class="cv-entry cv-entry-compact">
          <div class="cv-entry-head">
            <div class="cv-entry-title">{r.title}</div>
            <div class="cv-entry-date">{r.year}</div>
          </div>
          <div class="cv-entry-role">{r.composer} · Live recording</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── COMPOSITION CATALOGUE ──────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Compositions &amp; Arrangements</div>
    <div class="cv-entries">
      {catalogueSections.map((sec) => (
        <div>
          <div class="cv-sublabel" style="margin-top:24px">{sec.heading}</div>
          {sec.items.map((item) => (
            <div class="cv-entry cv-entry-compact">
              <div class="cv-entry-head">
                <div class="cv-entry-title" style="font-size:15px">{item.title}</div>
              </div>
              <div class="cv-entry-role">{item.forces}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ── AWARDS ─────────────────────────────────────────────────── -->
  <section class="section cv-section">
    <div class="cv-label">Grants &amp; Awards</div>
    <div class="cv-entries">
      <div class="cv-entry" style="padding-top:20px;padding-bottom:20px">
        <ul class="cv-list">
          {awards.map((a) => <li>{a}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── PRESS ──────────────────────────────────────────────────── -->
  <section class="section cv-section" style="padding-bottom:96px">
    <div class="cv-label">Press</div>
    <div class="cv-entries">
      {pressQuotes.map((p) => (
        <div class="cv-entry cv-entry-compact">
          <p class="cv-entry-body" style="font-style:italic">"{p.quote}"</p>
          <div class="cv-entry-role" style="margin-top:6px;margin-bottom:0">— {p.source}</div>
        </div>
      ))}
    </div>
  </section>

  <style>
    .cv-section{max-width:1480px;padding-left:40px;padding-right:40px;display:grid;grid-template-columns:220px 1fr;gap:40px;border-bottom:1px solid var(--line-soft)}
    .cv-section:last-of-type{border-bottom:none}
    .cv-label{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);padding-top:4px;font-weight:500}
    .cv-sublabel{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--line-soft);font-weight:500}
    .cv-entries{display:flex;flex-direction:column;gap:0}
    .cv-entry{padding:28px 0;border-bottom:1px solid var(--line-soft)}
    .cv-entry:last-child{border-bottom:none}
    .cv-entry-compact{padding:16px 0}
    .cv-entry-head{display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:6px}
    .cv-entry-title{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.15;letter-spacing:-.015em;color:var(--ink)}
    .cv-entry-date{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);white-space:nowrap;flex-shrink:0}
    .cv-entry-role{font-size:13px;color:var(--accent);font-weight:500;margin-bottom:10px;letter-spacing:-.005em}
    .cv-entry-body{font-size:14px;line-height:1.65;color:var(--ink-2);font-weight:350;max-width:72ch}
    .cv-entry-link{display:inline-flex;align-items:center;gap:6px;margin-top:10px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:500}
    .cv-entry-link:hover{text-decoration:underline}
    .cv-list{list-style:none;display:flex;flex-direction:column}
    .cv-list li{font-size:13.5px;color:var(--ink-2);padding:9px 0;border-bottom:1px solid var(--line-soft);font-weight:350}
    .cv-list li:last-child{border-bottom:none}
    .mentors-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
    .mentor-card{padding:14px;background:var(--bg);border:1px solid var(--line-soft);border-radius:6px}
    .mentor-name{font-family:var(--serif);font-size:16px;font-weight:400;color:var(--ink);margin-bottom:4px}
    .mentor-desc{font-size:12px;color:var(--muted);line-height:1.5}
    @media(max-width:900px){.cv-section{grid-template-columns:1fr;gap:20px;padding-left:20px;padding-right:20px}.mentors-grid{grid-template-columns:1fr}}
    @media(max-width:600px){.cv-entry-head{flex-direction:column;gap:4px}.cv-entry-title{font-size:18px}}

    /* ── CV page heading ── */
    .cv-page-head{max-width:1480px;margin:0 auto;padding:72px 40px 56px;border-bottom:1px solid var(--line-soft)}
    .cv-page-kicker{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--accent);margin-bottom:16px;font-weight:500}
    .cv-page-title{font-family:var(--serif);font-size:clamp(40px,6vw,72px);font-weight:400;line-height:1.05;letter-spacing:-.025em;color:var(--ink)}
    .cv-page-title em{font-style:italic;color:var(--muted)}
    @media(max-width:900px){.cv-page-head{padding:56px 20px 40px}}
    @media(max-width:600px){.cv-page-head{padding:48px 20px 32px}}

    /* ── Bio switcher ── */
    .bio-sw-section{padding-top:0;border-bottom:1px solid var(--line-soft);padding-bottom:64px}
    .bio-sw-head{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:36px}

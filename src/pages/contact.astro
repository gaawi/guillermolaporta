---
import SiteLayout from '../layouts/SiteLayout.astro';
---
<SiteLayout title='Contact - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Contact</div>
        <h1>Bookings / Projects / Press</h1>
        <p class='intro'>For performances, commissions, visual concert projects, stage design, interviews and collaborations.</p>
        <div class='button-row'>
          <a class='button primary' href='mailto:guillermo@creartbox.nyc'>guillermo@creartbox.nyc</a>
          <a class='button' href='https://creartbox.nyc' target='_blank' rel='noopener'>CreArtBox</a>
          <a class='button' href='https://festivaladar.com' target='_blank' rel='noopener'>Festival ADAR</a>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-4'>
        <div class='card light'><div class='meta'>01</div><h3>Performances</h3><p>Flute recitals, chamber music, visual concerts and touring programs.</p></div>
        <div class='card'><div class='meta'>02</div><h3>Commissions</h3><p>New music, transcriptions, multimedia works and site-responsive projects.</p></div>
        <div class='card'><div class='meta'>03</div><h3>Design</h3><p>Stage design, projections, lighting concepts and concert dramaturgy.</p></div>
        <div class='card'><div class='meta'>04</div><h3>Press</h3><p>Biography, interviews, project materials, images and institutional inquiries.</p></div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Social</div>
        <div>
          <h2>Project channels.</h2>
          <p class='lead'>Guillermo does not use personal social media. His work can be followed through CreArtBox and Festival ADAR.</p>
          <div class='button-row'>
            <a class='button' href='https://www.instagram.com/creartbox' target='_blank' rel='noopener'>@creartbox</a>
            <a class='button' href='https://www.instagram.com/festivaladar' target='_blank' rel='noopener'>@festivaladar</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

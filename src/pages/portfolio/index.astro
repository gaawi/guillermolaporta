---
import AppLayout from '../../layouts/AppLayout.astro';
import { projects } from '../../data/projects.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';

const catLabels = {
  opera:            'Opera & Ballet',
  multimedia:       'Multimedia Concert',
  'visual-concert': 'Visual Concert',
  theater:          'Theater',
};

const stageWorks = [...projects].sort((a, bk) => parseInt(bk.year) - parseInt(a.year));

const compositionSections = [
  {
    heading: 'Chamber Music',
    items: [
      { title: 'Twelve Preludes',            year: '2020', forces: 'Flute, with piano and media versions' },
      { title: 'Piano Trio "Craziest Thing"', year: '2019', forces: 'Violin, cello and piano' },
      { title: 'Traveling · Balance · Ballet',year: '2018', forces: 'Solo piano — three pieces' },
    ],
  },
  {
    heading: 'Electroacoustic Works',
    items: [
      { title: 'Música de Cristal',   year: '2025', forces: 'Flute, electronics and amplified glass' },
      { title: 'Progress > Defiance', year: '2023', forces: 'Live flute and electronics' },
      { title: 'Queens Log',          year: '2021', forces: 'Solo flute + field recordings' },
      { title: 'Harte Rate',          year: '2020', forces: 'Flute and electronics' },
    ],
  },
];

const arrangementSections = [
  {
    heading: 'Chamber Ensemble / Piano Quintet with Flute',
    items: [
      { title: 'Modest Mussorgsky — Pictures at an Exhibition',  forces: 'Piano quintet with flute' },
      { title: 'Igor Stravinsky — Petrushka',                   forces: 'Chamber ensemble with flute' },
      { title: 'Manuel de Falla — Siete canciones populares españolas', forces: 'Flute + ensemble' },
      { title: 'Frank Martin — Ballade',                        forces: 'Flute + chamber ensemble' },
      { title: 'György Ligeti — Musica Ricercata',              forces: 'Chamber arrangement' },
      { title: 'Antonín Dvořák — American String Quartet, Op. 96', forces: 'Chamber ensemble with flute' },
      { title: 'Antonín Dvořák — Piano Quintet No. 2, Op. 81', forces: 'Flute + piano quartet' },
    ],
  },
  {
    heading: 'Flute & Piano',
    items: [
      { title: 'Claude Debussy — Violin Sonata',              forces: 'Flute and piano' },
      { title: 'Ottorino Respighi — Violin Sonata in B minor',forces: 'Flute and piano' },
      { title: 'Leoš Janáček — Violin Sonata',                forces: 'Flute and piano' },
    ],
  },
];
---
<AppLayout title="Compositions Catalogue — Guillermo Laporta" description="Complete catalogue of original compositions and arrangements — Guillermo Laporta.">
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">Catalogue</div>
    <h1 class="subpage-title">Compositions <em>catalogue</em>.</h1>
    <p class="subpage-sub">Stage works, original compositions and arrangements — as composer, dramaturg and designer.</p>
  </div>

  <!-- ── STAGE WORKS ──────────────────────────────────────────── -->
  <section class="section cat-cv-section" style="padding-top:0">
    <div class="cv-label">Stage Works</div>
    <div class="cv-entries">
      {stageWorks.map((w) => (
        <div class="cv-entry cv-entry-compact">
          <div class="cv-entry-head">
            <div class="cv-entry-title">{w.title}</div>
            <div class="cv-entry-date">{w.year}</div>
          </div>
          <div class="cv-entry-role">{catLabels[w.cat] || w.cat} · {w.roles}</div>
          <p class="cv-entry-body">{w.desc}</p>
          <div class="cv-entry-links">
            <a class="cv-entry-link" href={`${b}portfolio/${w.slug}/`}>Gallery & details ↗</a>
            {w.url && <a class="cv-entry-link" href={w.url} target="_blank" rel="noopener">Project page ↗</a>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── ORIGINAL COMPOSITIONS ───────────────────────────────── -->
  <section class="section cat-cv-section">
    <div class="cv-label">Compositions</div>
    <div class="cv-entries">
      {compositionSections.map((sec) => (
        <div>
          <div class="cv-sublabel">{sec.heading}</div>
          {sec.items.map((item) => (
            <div class="cv-entry cv-entry-compact">
              <div class="cv-entry-head">
                <div class="cv-entry-title" style="font-size:16px">{item.title}</div>
                {item.year && <div class="cv-entry-date">{item.year}</div>}
              </div>
              <div class="cv-entry-role">{item.forces}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ── ARRANGEMENTS ─────────────────────────────────────────── -->
  <section class="section cat-cv-section" style="padding-bottom:96px">
    <div class="cv-label">Arrangements</div>
    <div class="cv-entries">
      {arrangementSections.map((sec) => (
        <div>
          <div class="cv-sublabel">{sec.heading}</div>
          {sec.items.map((item) => (
            <div class="cv-entry cv-entry-compact">
              <div class="cv-entry-head">
                <div class="cv-entry-title" style="font-size:16px">{item.title}</div>
              </div>
              <div class="cv-entry-role">{item.forces}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

  <style>
    .cat-cv-section{display:grid;grid-template-columns:220px 1fr;gap:40px;border-bottom:1px solid var(--line-soft);padding-top:56px;padding-bottom:56px}
    .cat-cv-section:last-of-type{border-bottom:none}
    @media(max-width:900px){.cat-cv-section{grid-template-columns:1fr;gap:20px}}

    .cv-label{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);padding-top:4px;font-weight:500}
    .cv-sublabel{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-top:24px;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--line-soft);font-weight:500}

    .cv-entries{display:flex;flex-direction:column;gap:0}
    .cv-entry{padding:28px 0;border-bottom:1px solid var(--line-soft)}
    .cv-entry:last-child{border-bottom:none}
    .cv-entry-compact{padding:16px 0}

    .cv-entry-head{display:flex;align-items:baseline;justify-content:space-between;gap:16px;margin-bottom:6px}
    .cv-entry-title{font-family:var(--serif);font-size:22px;font-weight:400;line-height:1.15;letter-spacing:-.015em;color:var(--ink)}
    .cv-entry-date{font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);white-space:nowrap;flex-shrink:0}
    .cv-entry-role{font-size:13px;color:var(--accent);font-weight:500;margin-bottom:10px;letter-spacing:-.005em}
    .cv-entry-body{font-size:14px;line-height:1.65;color:var(--ink-2);font-weight:350;max-width:72ch;margin-bottom:10px}

    .cv-entry-links{display:flex;flex-wrap:wrap;gap:20px}
    .cv-entry-link{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:500;text-decoration:none}
    .cv-entry-link:hover{text-decoration:underline}

    @media(max-width:600px){
      .cv-entry-head{flex-direction:column;gap:4px}
      .cv-entry-title{font-size:18px}
    }
  </style>
</AppLayout>

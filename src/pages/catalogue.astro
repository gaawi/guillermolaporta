---
import SiteLayout from '../layouts/SiteLayout.astro';
import { catalogue } from '../data/site.js';
---
<SiteLayout title='Composer Catalogue - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero' style="--hero-image:url('https://creartbox-media-cdn.b-cdn.net/webimg/projects_photos/acm/acm06.jpg')">
      <div>
        <div class='eyebrow'>Composer catalogue</div>
        <h1>Works / Scores / Media</h1>
        <p class='intro'>Original compositions, opera, ballet, multimedia music, visual concerts and stage works.</p>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Catalogue</div>
        <div class='table-list'>
          {catalogue.map((work) => (
            <div class='row'>
              <strong>{work.title}</strong>
              <span>{work.category}<br />{work.instrumentation}</span>
              <span>{work.year}</span>
              <span>{work.duration}<br />{work.notes}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

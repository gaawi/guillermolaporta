---
import SiteLayout from '../layouts/SiteLayout.astro';
import { catalogue } from '../data/site.js';
---
<SiteLayout title='Composer Catalogue - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Composer catalogue</div>
        <h1>Works / Scores / Media</h1>
        <p class='intro'>A working catalogue of original compositions, opera, ballet, multimedia music, visual concerts and stage works.</p>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Catalogue</div>
        <div class='table-list'>
          {catalogue.map((work) => (
            <div class='row'>
              <strong>{work.title}</strong>
              <span>{work.category}<br />{work.instrumentation}</span>
              <span>{work.year}</span>
              <span>{work.duration}<br />{work.notes}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-2'>
        <div>
          <div class='label'>Composer statement</div>
          <h2>Not only sound. A complete theatrical score.</h2>
          <p class='lead'>The catalogue includes concert music, chamber music, opera, ballet, video, electronics and works where the staging itself becomes part of the composition.</p>
        </div>
        <div class='visual-block' data-title='Catalogue'></div>
      </div>
    </section>
  </main>
</SiteLayout>

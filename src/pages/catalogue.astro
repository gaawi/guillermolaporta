---
import AppLayout from '../layouts/AppLayout.astro';
import { catalogue } from '../data/site.js';

const b = import.meta.env.BASE_URL;

const operas = catalogue.filter(w => w.category.toLowerCase().includes('opera') || w.category.toLowerCase().includes('ballet') || w.category.toLowerCase().includes('theater'));
const chamber = catalogue.filter(w => w.category.toLowerCase().includes('chamber') || w.category.toLowerCase().includes('solo') || w.category.toLowerCase().includes('flute'));
const multimedia = catalogue.filter(w => w.category.toLowerCase().includes('multimedia') || w.category.toLowerCase().includes('electro') || w.category.toLowerCase().includes('visual'));
const other = catalogue.filter(w => !operas.includes(w) && !chamber.includes(w) && !multimedia.includes(w));
---
<AppLayout title="Composer Catalogue — Guillermo Laporta" description="Original compositions, opera, ballet, multimedia music, visual concerts and stage works.">
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">01 — Composer Catalogue</div>
    <h1 class="subpage-title">Works &amp; <em>scores</em>.</h1>
    <p class="subpage-sub">Original compositions organized by category. Opera, chamber music, multimedia works, electroacoustic and stage pieces.</p>
  </div>

  <section class="section section-tight">
    <div class="catalogue-grid">
      {operas.length > 0 && (
        <div class="cat-block">
          <div class="cat-heading">Opera / Stage / Theater</div>
          <ul class="cat-list">
            {operas.map((w) => (
              <li>
                <span class="cat-title">{w.title} <small style="font-size:11px;font-family:var(--mono);color:var(--muted);margin-left:8px">{w.year}</small></span>
                <span class="cat-forces">{w.instrumentation}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {chamber.length > 0 && (
        <div class="cat-block">
          <div class="cat-heading">Chamber & Solo</div>
          <ul class="cat-list">
            {chamber.map((w) => (
              <li>
                <span class="cat-title">{w.title} <small style="font-size:11px;font-family:var(--mono);color:var(--muted);margin-left:8px">{w.year}</small></span>
                <span class="cat-forces">{w.instrumentation}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {multimedia.length > 0 && (
        <div class="cat-block">
          <div class="cat-heading">Multimedia & Electroacoustic</div>
          <ul class="cat-list">
            {multimedia.map((w) => (
              <li>
                <span class="cat-title">{w.title} <small style="font-size:11px;font-family:var(--mono);color:var(--muted);margin-left:8px">{w.year}</small></span>
                <span class="cat-forces">{w.instrumentation}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
      {other.length > 0 && (
        <div class="cat-block">
          <div class="cat-heading">Other Works</div>
          <ul class="cat-list">
            {other.map((w) => (
              <li>
                <span class="cat-title">{w.title} <small style="font-size:11px;font-family:var(--mono);color:var(--muted);margin-left:8px">{w.year}</small></span>
                <span class="cat-forces">{w.instrumentation}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <div style="margin-top:48px;padding-top:32px;border-top:1px solid var(--line-soft);display:flex;justify-content:center">
      <a class="btn" href={`${b}discography/`}>Recordings & Albums <span class="arr">→</span></a>
    </div>
  </section>

  <style>
    .section-tight{padding-top:0;max-width:1480px;margin:0 auto;padding-left:40px;padding-right:40px;padding-bottom:96px}
    @media(max-width:720px){.section-tight{padding-left:20px;padding-right:20px;padding-bottom:56px}}
  </style>
</AppLayout>

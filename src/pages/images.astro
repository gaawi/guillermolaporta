---
import SiteLayout from '../layouts/SiteLayout.astro';
import { mediaImages } from '../data/media.js';
---
<SiteLayout title='Images - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Images</div>
        <h1>Gallery / Archive</h1>
        <p class='intro'>A visual archive drawing from public CreArtBox performance materials, including portraits, stage work, visual concerts, venues and multimedia projects.</p>
      </div>
    </section>

    <section class='section'>
      <div class='grid-3'>
        {mediaImages.map((item) => (
          <figure class='image-card'>
            <img src={item.src} alt={item.alt} loading='lazy' onerror="this.closest('figure').classList.add('image-error'); this.remove();" />
            <figcaption>{item.title} / {item.category}</figcaption>
            <div class='visual-block image-fallback' data-title={item.title}></div>
          </figure>
        ))}
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Source</div>
        <div>
          <h2>Performance archive.</h2>
          <p class='lead'>These images are pulled from the public CreArtBox media archive. The gallery is structured so we can swap or expand images quickly as better portrait, installation and stage-design URLs are confirmed.</p>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

---
import SiteLayout from '../layouts/SiteLayout.astro';
import { mediaImages } from '../data/media.js';
---
<SiteLayout title='Images - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero' style={`--hero-image:url(${mediaImages[2].src})`}>
      <div>
        <div class='eyebrow'>Images</div>
        <h1>Gallery / Archive</h1>
        <p class='intro'>Portraits, performances, stage work, visual concerts, venues and multimedia projects.</p>
      </div>
    </section>

    <section class='section'>
      <div class='grid-3'>
        {mediaImages.map((item) => (
          <figure class='image-card'>
            <img src={item.src} alt={item.alt} loading='lazy' />
            <figcaption>{item.title} / {item.category}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>

---
import SiteLayout from '../layouts/SiteLayout.astro';
import { archive } from '../data/site.js';
const years = [...new Set(archive.map(e => e.year))].sort((a,b) => b - a);
const series = [...new Set(archive.map(e => e.series))].sort();
---
<SiteLayout title='Archive - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero' style="--hero-image:url('/images/2023-03-architecture.jpg')">
      <div>
        <div class='eyebrow'>Archive</div>
        <h1>A decade &amp; a half.</h1>
        <p class='intro'>{archive.length} performances · 2009 → 2025</p>
      </div>
    </section>

    <section class='section'>
      <div class='archive-grid'>
        {archive.map((item) => (
          <article class='archive-card'>
            <div class='archive-img'>
              <img src={item.image} alt={item.title} loading='lazy' />
            </div>
            <div class='archive-info'>
              <div class='archive-meta'>{item.date.replace('-00','').replace('-', ' · ')} · {item.series}</div>
              <div class='archive-title'>{item.title}</div>
              <div class='archive-venue'>{item.venue}</div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .archive-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:40px 0}
  .archive-card{border:1px solid var(--line-strong);border-radius:18px;overflow:hidden;background:rgba(245,241,232,.04)}
  .archive-img{aspect-ratio:16/9;background:#111;overflow:hidden}
  .archive-img img{width:100%;height:100%;object-fit:cover;filter:grayscale(.6);transition:filter .25s,transform .25s}
  .archive-card:hover img{filter:grayscale(0);transform:scale(1.03)}
  .archive-info{padding:12px 14px}
  .archive-meta{color:var(--clay);font-size:.65rem;font-weight:900;text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
  .archive-title{font-size:.92rem;font-weight:700;letter-spacing:-.02em;margin-bottom:2px}
  .archive-venue{color:var(--muted);font-size:.78rem}
  @media(max-width:900px){.archive-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.archive-grid{grid-template-columns:1fr}}
</style>

---
import AppLayout from '../layouts/AppLayout.astro';
import { archive } from '../data/site.js';

const b = import.meta.env.BASE_URL;
const years = [...new Set(archive.map(e => e.year))].sort((a, b) => b - a);
---
<AppLayout title="Archive — Guillermo Laporta" description={`${archive.length} productions · 2009 → 2025`}>
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">Archive</div>
    <h1 class="subpage-title">A decade <em>&amp;</em> a half.</h1>
    <p class="subpage-sub">{archive.length} productions · 2009 → 2025</p>
  </div>

  <section class="section section-tight">
    <div class="archive-grid">
      {archive.map((item) => (
        <article class="arch-card">
          <div class="arch-img">
            <img src={`${b}${item.image.replace(/^\//,'')}`} alt={item.title} loading="lazy" />
          </div>
          <div class="arch-meta">
            <span>{item.date.replace('-00','').replace('-', ' · ')}</span>
            <span>{item.series}</span>
          </div>
          <div class="arch-title">{item.title}</div>
          <div class="arch-venue">{item.venue}</div>
        </article>
      ))}
    </div>
  </section>

  <style>
    .section-tight{padding-top:0;max-width:1480px;margin:0 auto;padding-left:40px;padding-right:40px;padding-bottom:96px}
    @media(max-width:720px){.section-tight{padding-left:20px;padding-right:20px;padding-bottom:56px}}
  </style>
</AppLayout>

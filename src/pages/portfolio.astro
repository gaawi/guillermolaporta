---
import AppLayout from '../layouts/AppLayout.astro';
import { projects } from '../data/projects.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';

function imgSrc(src) {
  if (!src) return '';
  if (src.startsWith('http')) return src;
  return `${b}${src.replace(/^\//, '')}`;
}
---
<AppLayout title="Portfolio — Guillermo Laporta" description="Selected creative works: opera, ballet, multimedia concert, visual concert and theater.">
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">02 — Portfolio</div>
    <h1 class="subpage-title">Selected <em>works</em>.</h1>
    <p class="subpage-sub">Opera, ballet, multimedia concert, visual concert and theater — as composer, director and designer.</p>
  </div>

  <section class="section section-tight">
    <div class="proj-grid">
      {projects.map((p) => (
        <article class="proj-card">
          <div class="proj-img-wrap">
            <img
              class="proj-img"
              src={imgSrc(p.image)}
              alt={p.title}
              loading="lazy"
            />
          </div>
          <div class="proj-body">
            <div class="proj-meta">
              <span class="proj-year">{p.year}</span>
            </div>
            <h2 class="proj-title">{p.title}</h2>
            <div class="proj-roles">{p.roles}</div>
            <p class="proj-desc">{p.desc}</p>
            {p.url && (
              <a class="proj-link" href={p.url} target="_blank" rel="noopener">
                Project page <span class="arr">↗</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <style>
    .section-tight{padding-top:0;max-width:1480px;margin:0 auto;padding-left:40px;padding-right:40px;padding-bottom:96px}
    @media(max-width:720px){.section-tight{padding-left:20px;padding-right:20px;padding-bottom:56px}}

    .proj-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px}
    @media(max-width:900px){.proj-grid{grid-template-columns:1fr}}

    .proj-card{display:flex;flex-direction:column;background:var(--surface);border:1px solid var(--line-soft);overflow:hidden}

    .proj-img-wrap{aspect-ratio:16/9;overflow:hidden;background:var(--line-soft)}
    .proj-img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease}
    .proj-card:hover .proj-img{transform:scale(1.03)}

    .proj-body{padding:28px 32px 32px;display:flex;flex-direction:column;flex:1}
    @media(max-width:600px){.proj-body{padding:20px}}

    .proj-meta{display:flex;align-items:center;gap:12px;margin-bottom:10px}
    .proj-year{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}

    .proj-title{font-family:var(--serif);font-size:26px;font-weight:400;line-height:1.15;letter-spacing:-.015em;color:var(--ink);margin-bottom:8px}
    @media(max-width:600px){.proj-title{font-size:22px}}

    .proj-roles{font-size:12px;color:var(--accent);font-weight:500;letter-spacing:.01em;margin-bottom:14px}

    .proj-desc{font-size:14px;line-height:1.65;color:var(--ink-2);font-weight:350;flex:1;max-width:56ch}

    .proj-link{display:inline-flex;align-items:center;gap:6px;margin-top:20px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:500;text-decoration:none}
    .proj-link:hover{text-decoration:underline}
    .arr{font-size:12px}
  </style>
</AppLayout>

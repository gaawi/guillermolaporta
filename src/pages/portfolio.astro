---
import SiteLayout from '../layouts/SiteLayout.astro';
import { projects } from '../data/projects.js';
---
<SiteLayout title="Portfolio - Guillermo Laporta">
  <main class="page portfolio-page">
    <section class="portfolio-hero">
      <img src={projects[0].image} alt={projects[0].title} />
      <div class="portfolio-hero-content">
        <div class="eyebrow">Portfolio</div>
        <h1>Projects</h1>
      </div>
    </section>

    <section class="portfolio-section">
      <div class="portfolio-grid">
        {projects.map((p, i) => (
          <>
            <a class="project-card" href={`#project-${i}`}>
              <div class="project-image"><img src={p.image} alt={p.title} loading="lazy" /></div>
              <div class="project-caption"><strong>{p.title}</strong><span>{p.year} · {p.type}</span></div>
            </a>
            <aside id={`project-${i}`} class="project-popup">
              <a class="popup-backdrop" href="#portfolio"></a>
              <div class="popup-panel">
                <a class="popup-close" href="#portfolio">Close</a>
                <div class="popup-image"><img src={p.image} alt={p.title} /></div>
                <div class="popup-body">
                  <p class="popup-meta">{p.year} · {p.type}</p>
                  <h2>{p.title}</h2>
                  <p>{p.long}</p>
                  <p class="popup-roles">{p.roles.join(' · ')}</p>
                  <div class="button-row"><a class="button primary" href={p.url} target="_blank" rel="noopener">Open project</a></div>
                </div>
              </div>
            </aside>
          </>
        ))}
      </div>
    </section>
  </main>

  <style>
    .portfolio-page{width:min(1180px,calc(100% - 24px))}.portfolio-hero{position:relative;height:clamp(260px,42vw,520px);margin-top:18px;overflow:hidden;border-radius:28px;border:1px solid rgba(245,241,232,.22);background:#111}.portfolio-hero img{width:100%;height:100%;object-fit:cover}.portfolio-hero:after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.05),rgba(0,0,0,.78))}.portfolio-hero-content{position:absolute;z-index:2;left:24px;right:24px;bottom:24px}.portfolio-hero h1{margin:0;font-size:clamp(2.2rem,7vw,5.8rem);line-height:.9}.portfolio-section{padding:32px 0 64px}.portfolio-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px}.project-card{display:block}.project-image{aspect-ratio:16/9;overflow:hidden;border-radius:20px;border:1px solid rgba(245,241,232,.18);background:#111}.project-image img{width:100%;height:100%;object-fit:cover;transition:transform .25s ease}.project-card:hover img{transform:scale(1.02)}.project-caption{display:grid;gap:3px;padding:10px 2px 0}.project-caption strong{font-size:.98rem;letter-spacing:-.02em}.project-caption span{color:rgba(245,241,232,.58);font-size:.76rem;line-height:1.35}.project-popup{display:none;position:fixed;inset:0;z-index:100}.project-popup:target{display:block}.popup-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(12px)}.popup-panel{position:relative;width:min(820px,94vw);max-height:92vh;margin:4vh auto;background:rgba(10,10,10,.96);color:#f5f1e8;border-radius:28px;overflow:auto;box-shadow:0 30px 100px rgba(0,0,0,.65)}.popup-close{position:absolute;z-index:3;top:14px;right:14px;border:1px solid rgba(245,241,232,.22);border-radius:999px;padding:9px 12px;background:rgba(0,0,0,.58);font-size:.72rem;text-transform:uppercase;letter-spacing:.08em;font-weight:800}.popup-image{aspect-ratio:16/9;background:#111}.popup-image img{width:100%;height:100%;object-fit:cover}.popup-body{padding:24px}.popup-meta,.popup-roles{color:rgba(245,241,232,.6);font-size:.82rem;line-height:1.45}.popup-body h2{margin:6px 0 14px;font-size:clamp(1.8rem,5vw,3.6rem);line-height:.95}.popup-body p{color:rgba(245,241,232,.78);font-size:1rem;line-height:1.62;max-width:62ch}@media(max-width:760px){.portfolio-page{width:min(100% - 20px,1180px)}.portfolio-hero{height:230px;border-radius:22px;margin-top:12px}.portfolio-hero-content{left:16px;right:16px;bottom:16px}.portfolio-hero h1{font-size:2.2rem}.portfolio-section{padding:22px 0 42px}.portfolio-grid{grid-template-columns:1fr;gap:18px}.project-image{border-radius:17px}.popup-panel{width:96vw;max-height:90vh;border-radius:22px}.popup-body{padding:18px}.popup-body h2{font-size:1.9rem}.popup-body p{font-size:.96rem}}
  </style>
</SiteLayout>

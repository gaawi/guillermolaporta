---
import SiteLayout from '../layouts/SiteLayout.astro';
import { projects } from '../data/projects.js';
---

<SiteLayout title="Portfolio - Guillermo Laporta">
  <main class="page">

    <section class="page-hero">
      <div>
        <div class="eyebrow">Portfolio</div>
        <h1>Projects</h1>
      </div>
    </section>

    <section class="section">
      <div class="grid-2">

        {projects.map((p, i) => (
          <>
            <article 
              class="image-card"
              onclick={`document.getElementById('modal-${i}').showModal()`}
            >
              <img src={p.image} alt={p.title} />
              <figcaption>{p.title}</figcaption>
            </article>

            <dialog id={`modal-${i}`} class="modal">
              <div class="modal-content">

                <h2>{p.title}</h2>
                <p><strong>{p.year} · {p.type}</strong></p>

                <p>{p.long}</p>

                <p><strong>Roles:</strong> {p.roles.join(', ')}</p>

                <div class="button-row">
                  <a 
                    class="button primary" 
                    href={p.url} 
                    target="_blank"
                  >
                    View full project
                  </a>

                  <button 
                    class="button" 
                    onclick={`document.getElementById('modal-${i}').close()`}
                  >
                    Close
                  </button>
                </div>

              </div>
            </dialog>
          </>
        ))}

      </div>
    </section>

  </main>

  <style>
    .modal {
      border: none;
      background: rgba(0,0,0,0.92);
      color: white;
      width: min(720px, 90vw);
    }

    .modal-content {
      padding: 24px;
    }
  </style>

</SiteLayout>
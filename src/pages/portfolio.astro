---
import SiteLayout from '../layouts/SiteLayout.astro';
import { portfolio } from '../data/site.js';
import { mediaImages } from '../data/media.js';
---
<SiteLayout title='Portfolio - Guillermo Laporta'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Portfolio</div>
        <h1>Visual / Stage / Media</h1>
        <p class='intro'>Selected works as visual artist, stage designer, composer, dramaturg and multimedia creator.</p>
      </div>
    </section>

    <section class='section'>
      <div class='grid-2'>
        {mediaImages.slice(0, 4).map((item) => (
          <figure class='image-card'>
            <img src={item.src} alt={item.alt} loading='lazy' />
            <figcaption>{item.title} / {item.category}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class='section'>
      <div class='grid-2'>
        {portfolio.map((item) => (
          <article class='card'>
            <div class='meta'>{item.year} / {item.type}</div>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <div class='tag-row'>
              {item.tags.map((tag) => <span class='tag'>{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</SiteLayout>

---
import AppLayout from '../layouts/AppLayout.astro';
import { press } from '../data/site.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';
---
<AppLayout title="Press — Guillermo Laporta" description="Selected press coverage of CreArtBox, Festival ADAR and Guillermo Laporta's productions.">
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">06 — Press</div>
    <h1 class="subpage-title">Selected <em>press</em>.</h1>
    <p class="subpage-sub">Coverage of CreArtBox, Festival ADAR and Guillermo Laporta's productions.</p>
  </div>

  <section class="section section-tight">
    <div class="press-grid">
      {press.map((item) => (
        <div class="press-card">
          <div class="press-mark">"</div>
          <div class="press-quote">{item.quote}</div>
          <div class="press-source">{item.source}</div>
        </div>
      ))}
    </div>

    <div style="margin-top:72px;padding-top:40px;border-top:1px solid var(--line-soft)">
      <div class="disco-section-label">Press kit</div>
      <p style="font-size:15px;line-height:1.65;color:var(--ink-2);margin-bottom:28px">Press photos, CV and bio available for download.</p>
      <div style="display:flex;flex-wrap:wrap;gap:12px">
        <a class="btn primary" href={`${b}downloads/guillermo-laporta-cv.pdf`} target="_blank">CV — PDF ↗</a>
        <a class="btn" href={`${b}downloads/laporta-press-photo-1.jpg`} target="_blank">Press photo 1</a>
        <a class="btn" href={`${b}downloads/laporta-press-photo-2.jpg`} target="_blank">Press photo 2</a>
        <a class="btn" href="mailto:guillermo@creartbox.nyc">Press enquiries</a>
      </div>
    </div>
  </section>

  <style>
    .section-tight{padding-top:0;max-width:1480px;margin:0 auto;padding-left:40px;padding-right:40px;padding-bottom:96px}
    @media(max-width:720px){.section-tight{padding-left:20px;padding-right:20px;padding-bottom:56px}}
  </style>
</AppLayout>

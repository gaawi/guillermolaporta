---
import AppLayout from '../layouts/AppLayout.astro';
import { calendar, visualWork, albums, liveRecordings, bio } from '../data/site.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';
const today = new Date().toISOString().split('T')[0];
const upcoming = calendar.filter(e => e.date >= today).slice(0, 4);
const featuredWork = visualWork.slice(0, 3);
const portraitImg = `${b}downloads/laporta-press-photo-1.jpg`;
---
<AppLayout
  title="Guillermo Laporta — Flutist · Composer · Director"
  description="Guillermo Laporta is a flutist, composer and cultural producer based between New York City and Asturias, Spain. Founder of CreArtBox and Festival ADAR."
>
  <!-- ── HERO ─────────────────────────────────────────────────── -->
  <section class="hero" id="top">
    <div class="hero-grid">
      <div class="hero-left">
        <div class="hero-eyebrow">
          <span class="line"></span>
          <span>Flutist · Composer · Director</span>
          <span>— New York</span>
        </div>
        <h1 class="hero-title">
          <span class="row">Flutist, composer</span>
          <span class="row"><em>&</em> producer in NYC.</span>
        </h1>
        <p class="hero-sub">
          Guillermo Laporta works between <b>New York</b> and <b>Asturias</b> across
          chamber music, opera, multimedia performance and concert design.
          He develops productions that bring classical music to new and broader audiences —
          through visual concerts, interdisciplinary collaboration and cultural entrepreneurship.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={`${b}portfolio/`}>Catalogue <span class="arr">→</span></a>
          <a class="btn" href={`${b}visual-art/`}>Visual Art</a>
          <a class="btn" href={`${b}calendar/`}>Upcoming dates</a>
        </div>
      </div>
      <div>
        <div class="hero-card">
          <div class="img">
            <img src={portraitImg} alt="Guillermo Laporta" loading="eager" />
          </div>
          <div class="body">
            <div>
              <div class="meta">Upcoming · Aug 2026</div>
              <h3>Festival ADAR 2026</h3>
              <div class="where">Multiple venues · Asturias, Spain</div>
            </div>
            <span class="badge">Festival</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT / STATEMENT ─────────────────────────────────────── -->
  <section class="section" id="about">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">01 — Practice</div>
        <h2 class="section-title">Music for <em>broader</em><br />audiences.</h2>
      </div>
      <div class="section-rhs">
        Composition, concert design and cultural entrepreneurship at the intersection of classical music, visual art and theatre.
      </div>
    </div>
    <div class="statement">
      <div class="quote-mark">"</div>
      <div class="statement-body">
        <p>The concert can be a <em>total experience</em> — music, image, space and story arriving together. I design my productions to reach people who may not have grown up with classical music, but respond immediately when it is presented in the right visual and theatrical context.</p>
        <p>My work runs across three areas: original composition (opera, chamber music, multimedia works); concert design that integrates projection, lighting and spatial narrative; and building organisations — CreArtBox in New York and Festival ADAR in rural Asturias — that create genuine access to this kind of work.</p>
        <div class="statement-sig">Guillermo Laporta · New York, 2026</div>
      </div>
    </div>
  </section>

  <!-- ── LEADERSHIP ─────────────────────────────────────────────── -->
  <section class="section" id="leadership">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">02 — Leadership</div>
        <h2 class="section-title">Building <em>organisations</em>.</h2>
      </div>
    </div>
    <div class="leadership-grid">
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">CreArtBox</div>
          <div class="lead-period">New York · 2013 – present</div>
          <div class="lead-role">Co-founder & Executive Director</div>
        </div>
        <div class="lead-body">
          Chamber music and multimedia performing arts organization. 20+ professional artists, 20+ performances per season at The DiMenna Center, Mark Morris Center, The William Vale, Greenwich House and more. Sustained support from NYSCA. Covered by The New Yorker, Broadway World, Time Out.
        </div>
        <a class="lead-link" href="https://creartbox.nyc" target="_blank" rel="noopener">creartbox.nyc ↗</a>
      </div>
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">Festival ADAR</div>
          <div class="lead-period">Asturias · 2020 – present</div>
          <div class="lead-role">Founder & Artistic Director</div>
        </div>
        <div class="lead-body">
          Itinerant festival bringing world-class chamber music, composer commissions and visual installations to underserved rural communities in Asturias, Spain. Supported by the Government of Asturias with €120,000 across four awards (2021–25).
        </div>
        <a class="lead-link" href="https://festivaladar.com" target="_blank" rel="noopener">festivaladar.com ↗</a>
      </div>
      <div class="lead-card">
        <div class="lead-head">
          <div class="lead-org">CreArt Music Series</div>
          <div class="lead-period">New York · 2008 – 2013</div>
          <div class="lead-role">Founder & Artistic Director</div>
        </div>
        <div class="lead-body">
          Annual chamber music series at the Kosciuszko Foundation (Manhattan) that presented 25+ concerts featuring international soloists and emerging composers. Predecessor to the CreArtBox nonprofit.
        </div>
      </div>
    </div>
  </section>

  <!-- ── PORTFOLIO PREVIEW ─────────────────────────────────────── -->
  <section class="section" id="portfolio-preview">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">03 — Visual work</div>
        <h2 class="section-title"><em>Visual</em> art portfolio.</h2>
      </div>
      <div class="section-rhs">
        Concert video, installations and theater design.
      </div>
    </div>
    <div class="va-grid">
      {featuredWork.map((w) => (
        <article class="va-card"
          data-lightbox
          data-img={`${b}${w.image.replace(/^\//,'')}`}
          data-title={w.title}
          data-year={w.year}
          data-kind={w.kind}
          data-desc={w.desc}
          data-url={w.url}
          tabindex="0"
          role="button"
          aria-label={`Open details for ${w.title}`}
        >
          <div class="va-img">
            <img src={`${b}${w.image.replace(/^\//,'')}`} alt={w.title} loading="lazy" />
            <span class="va-num">№ {w.num}</span>
          </div>
          <div class="va-meta">
            <span>{w.year}</span>
            <span>{w.kind}</span>
          </div>
          <h3 class="va-title">{w.title}</h3>
          <p class="va-desc">{w.desc}</p>
        </article>
      ))}
    </div>
    <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--line-soft);display:flex;justify-content:center">
      <a class="btn" href={`${b}portfolio/`}>All 15 works <span class="arr">→</span></a>
    </div>
  </section>

  <!-- ── CALENDAR ───────────────────────────────────────────────── -->
  <section class="section" id="calendar-preview">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">04 — Calendar</div>
        <h2 class="section-title">Upcoming <em>dates</em>.</h2>
      </div>
    </div>
    <div class="calendar">
      {upcoming.map((event, i) => (
        <div class="cal-row"
          data-lightbox
          data-img={`${b}${event.image.replace(/^\//,'')}`}
          data-title={event.title}
          data-year={event.year}
          data-kind={event.subtitle}
          data-desc={event.location}
          data-url={event.url}
          tabindex="0"
          role="button"
          aria-label={`Details for ${event.title}`}
        >
          <div class="ix">№{String(i+1).padStart(2,'0')}</div>
          <div class="when">
            {event.displayDate}
            <small>{event.year}</small>
          </div>
          <div class="name">
            {event.title}
            <small>{event.subtitle}</small>
          </div>
          <div class="venue">{event.location}</div>
          <div class="status">
            <span class="pill">{event.status} <span class="arr">→</span></span>
          </div>
        </div>
      ))}
    </div>
    <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--line-soft);display:flex;justify-content:center">
      <a class="btn" href={`${b}calendar/`}>Full calendar <span class="arr">→</span></a>
    </div>
  </section>

  <!-- ── RECORDINGS ─────────────────────────────────────────────── -->
  <section class="section" id="recordings">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">05 — Discography</div>
        <h2 class="section-title">Studio &amp; <em>live</em> recordings.</h2>
      </div>
      <div class="section-rhs">
        All releases on Bandcamp, also available on Spotify and Apple Music.
        <div style="margin-top:12px">
          <a class="btn" href="https://creartbox.bandcamp.com" target="_blank" rel="noopener" style="font-size:12px;padding:8px 16px">
            Bandcamp catalogue ↗
          </a>
        </div>
      </div>
    </div>
    <div class="disco-grid-dense">
      {liveRecordings.slice(0, 4).map((r) => (
        <a class="disco-card" href={r.url} target="_blank" rel="noopener">
          <div class="disco-cover">
            <img src={`${b}${r.cover.replace(/^\//,'')}`} alt={r.title} loading="lazy" />
          </div>
          <div class="disco-meta">
            <span>{r.year}</span>
            <span>Live</span>
          </div>
          <div class="disco-title">{r.title}</div>
          <div class="disco-artist">{r.composer}</div>
        </a>
      ))}
    </div>
    <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--line-soft);display:flex;justify-content:center">
      <a class="btn" href={`${b}discography/`}>All recordings <span class="arr">→</span></a>
    </div>
  </section>

  <!-- ── PRESS ──────────────────────────────────────────────────── -->
  <section class="section" id="press">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">06 — Press</div>
        <h2 class="section-title">Selected <em>press</em>.</h2>
      </div>
    </div>
    <div class="press-grid">
      <div class="press-card">
        <div class="press-mark">"</div>
        <div class="press-quote">Critics top pick for the best music, art and theatre.</div>
        <div class="press-source">The New Yorker</div>
      </div>
      <div class="press-card">
        <div class="press-mark">"</div>
        <div class="press-quote">A remarkable production fusing together a variety of art forms to create a wholly authentic, visually and aurally compelling experience.</div>
        <div class="press-source">Broadway World</div>
      </div>
      <div class="press-card">
        <div class="press-mark">"</div>
        <div class="press-quote">The CreArtBox Music Festival has solidified its presence as one of the most sought-after classical music festivals.</div>
        <div class="press-source">Broadway World</div>
      </div>
    </div>
    <div style="margin-top:40px;padding-top:32px;border-top:1px solid var(--line-soft);display:flex;justify-content:center">
      <a class="btn" href={`${b}press/`}>All press <span class="arr">→</span></a>
    </div>
  </section>

  <!-- ── BIO / ABOUT ───────────────────────────────────────── -->
  <section class="section" id="about-bio">
    <div class="section-head">
      <div class="lhs">
        <div class="section-num">07 — About</div>
        <h2 class="section-title">Flutist, composer<br /><em>&amp; producer</em>.</h2>
      </div>
    </div>

    <div class="biostrip">
      <div class="biostrip-text">
        <h3>Flutist, composer <em>&amp;</em> cultural producer.</h3>
        <p>{bio.short}</p>
        <div class="bio-stats">
          <div class="stat"><div class="num">13<em>+</em></div><div class="lbl">Years NYC</div></div>
          <div class="stat"><div class="num">55<em>+</em></div><div class="lbl">Productions</div></div>
          <div class="stat"><div class="num">2</div><div class="lbl">Companies</div></div>
          <div class="stat"><div class="num"><em>€</em>120k</div><div class="lbl">EU Grants</div></div>
        </div>
      </div>
      <div class="bio-side">
        <div class="bio-card dark">
          <div class="lbl">Based</div>
          <div class="val">New York · <em>Asturias</em></div>
          <div class="desc">Between New York City and Spain since 2012.</div>
        </div>
        <div class="bio-card">
          <div class="lbl">Current status</div>
          <div class="val">NYC · <em>Composing</em></div>
          <div class="desc">Working on the 2026–27 season programmes.</div>
        </div>
        <div class="bio-card">
          <div class="lbl">Education</div>
          <div class="val">RCM London · <em>Musikene</em></div>
          <div class="desc">M.Mus. Advanced Performance (Jaime Martín, Paul Edmund Davies). M.A. Arts Management.</div>
        </div>
      </div>
    </div>

    <div class="bio-long">
      {bio.long.map((para) => (
        <p class="bio-para">{para}</p>
      ))}
    </div>

    <div class="bio-kit">
      <div class="bio-kit-label">Press kit</div>
      <div class="bio-kit-links">
        <a class="btn primary" href={`${b}downloads/guillermo-laporta-cv.pdf`} target="_blank">CV — PDF ↗</a>
        <a class="btn" href={`${b}downloads/laporta-press-photo-1.jpg`} target="_blank">Press photo 1</a>
        <a class="btn" href={`${b}downloads/laporta-press-photo-2.jpg`} target="_blank">Press photo 2</a>
        <a class="btn" href="mailto:guillermo@creartbox.nyc">Press enquiries</a>
      </div>
    </div>
  </section>

  <style>
    .bio-long{max-width:72ch;margin:48px 0 0}
    .bio-para{font-size:16px;line-height:1.75;color:var(--ink-2);font-weight:350;margin-bottom:18px}
    @media(max-width:600px){.bio-para{font-size:15px}}
    .bio-kit{margin-top:48px;padding-top:32px;border-top:1px solid var(--line-soft)}
    .bio-kit-label{font-family:var(--mono);font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:16px}
    .bio-kit-links{display:flex;flex-wrap:wrap;gap:12px}
  </style>
</AppLayout>

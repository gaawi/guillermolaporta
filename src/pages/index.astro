---
import SiteLayout from '../layouts/SiteLayout.astro';
import { calendar, portfolio, albums } from '../data/site.js';
const featured = portfolio.slice(0, 4);
---
<SiteLayout title='Guillermo Laporta - Personal Website'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Flutist / Composer / Visual Artist</div>
        <h1>Guillermo Laporta</h1>
        <p class='intro'>A personal archive for music, visual concerts, opera, video, installation, stage design, recordings and rural cultural projects between New York City and Asturias.</p>
        <div class='button-row'>
          <a class='button primary' href='/portfolio/'>Portfolio</a>
          <a class='button' href='/catalogue/'>Composer Catalogue</a>
          <a class='button' href='/calendar/'>Calendar</a>
          <a class='button' href='/bio/'>Bio</a>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Statement</div>
        <div>
          <h2>Music as image, theater and space.</h2>
          <p class='lead'>My work moves between flute performance, composition, stage design, video, cultural production and place-based projects. I am interested in concerts as total experiences, where sound, light, movement and architecture belong to the same score.</p>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-3'>
        <a class='card light' href='/portfolio/'>
          <div class='meta'>01 / Visual Work</div>
          <h3>Portfolio</h3>
          <p>Opera, video, installations, visual concerts, scenography and multimedia performance.</p>
        </a>
        <a class='card' href='/catalogue/'>
          <div class='meta'>02 / Music</div>
          <h3>Catalogue</h3>
          <p>A composer catalogue organized by work, year, category, instrumentation and duration.</p>
        </a>
        <a class='card' href='/discography/'>
          <div class='meta'>03 / Recordings</div>
          <h3>Discography</h3>
          <p>Albums, flute repertoire, transcriptions and multimedia recording projects.</p>
        </a>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Selected projects</div>
        <div class='grid-2'>
          {featured.map((item) => (
            <article class='card'>
              <div class='meta'>{item.year} / {item.type}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Upcoming / recent</div>
        <div class='table-list'>
          {calendar.map((event) => (
            <a class='row' href={event.url} target='_blank' rel='noopener'>
              <strong>{event.displayDate}</strong>
              <span>{event.title}</span>
              <span>{event.subtitle}</span>
              <span>{event.location}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-2'>
        <div class='visual-block' data-title='Visual Concert'></div>
        <div>
          <div class='label'>Design note</div>
          <h2>Brutalist, minimal, high contrast.</h2>
          <p class='lead'>This version intentionally avoids broken external images. The visual language is built first through typography, grid, contrast and abstract blocks. Real images can be added later only when we have verified URLs.</p>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Discography</div>
        <div class='grid-3'>
          {albums.map((album) => (
            <article class='card'>
              <div class='meta'>{album.year} / {album.format}</div>
              <h3>{album.title}</h3>
              <p>{album.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

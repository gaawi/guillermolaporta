---
import SiteLayout from '../layouts/SiteLayout.astro';
import { calendar, portfolio, albums } from '../data/site.js';
import { homeImages } from '../data/media.js';
const featured = portfolio.slice(0, 4);
---
<SiteLayout title='Guillermo Laporta - Flutist, Composer, Visual Artist'>
  <main class='page'>
    <section class='page-hero'>
      <div>
        <div class='eyebrow'>Flutist / Composer / Visual Artist</div>
        <h1>Guillermo Laporta</h1>
        <p class='intro'>Spanish flutist, composer and visual artist based between New York City and Asturias. His work connects chamber music, opera, video, stage design and site-specific creation.</p>
        <div class='button-row'>
          <a class='button primary' href='/portfolio/'>Portfolio</a>
          <a class='button' href='/catalogue/'>Composer Catalogue</a>
          <a class='button' href='/discography/'>Discography</a>
          <a class='button' href='/bio/'>Bio</a>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-3'>
        {homeImages.map((item) => (
          <figure class='image-card'>
            <img src={item.src} alt={item.alt} loading='lazy' />
            <figcaption>{item.title} / {item.category}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Practice</div>
        <div>
          <h2>Music, image and space.</h2>
          <p class='lead'>Laporta develops performances where sound, light, movement, projection and architecture become part of the same dramaturgical arc. His work moves between flute performance, composition, visual concert design, opera, ballet, installation and rural cultural projects.</p>
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='grid-3'>
        <a class='card light' href='/portfolio/'>
          <div class='meta'>Visual work</div>
          <h3>Portfolio</h3>
          <p>Opera, video, installations, visual concerts, scenography and multimedia performance.</p>
        </a>
        <a class='card' href='/catalogue/'>
          <div class='meta'>Composition</div>
          <h3>Catalogue</h3>
          <p>Original works organized by title, year, category, instrumentation and duration.</p>
        </a>
        <a class='card' href='/discography/'>
          <div class='meta'>Recordings</div>
          <h3>Discography</h3>
          <p>Albums, flute repertoire, transcriptions and multimedia recording projects.</p>
        </a>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Selected projects</div>
        <div class='grid-2'>
          {featured.map((item) => (
            <article class='card'>
              <div class='meta'>{item.year} / {item.type}</div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Calendar</div>
        <div class='table-list'>
          {calendar.map((event) => (
            <a class='row' href={event.url} target='_blank' rel='noopener'>
              <strong>{event.displayDate}</strong>
              <span>{event.title}</span>
              <span>{event.subtitle}</span>
              <span>{event.location}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class='section'>
      <div class='section-grid'>
        <div class='label'>Discography</div>
        <div class='grid-3'>
          {albums.map((album) => (
            <article class='card'>
              <div class='meta'>{album.year} / {album.format}</div>
              <h3>{album.title}</h3>
              <p>{album.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>

    embed: 'https://iframe.mediadelivery.net/embed/449741/925210c7-f30b-4a8a-b7e8-8f4d26c8150a?autoplay=true&loop=false&muted=false&preload=true&responsive=true',
  },
  {
    composer: 'Andrea Casarrubios',
    title: 'Afilador',
    year: '2023',
    role: 'Flute',
    type: 'video',
    cover: `${WP}/002.jpg`,
    embed: 'https://iframe.mediadelivery.net/embed/449741/d6914ec2-693c-4013-805e-356129f0375c?autoplay=true&loop=false&muted=false&preload=true&responsive=true',
  },
  {
    composer: 'Hannah Selin',
    title: 'Chesapeake',
    year: '2023',
    role: 'Flute',
    type: 'video',
    cover: `${WP}/004-4.jpg`,
    embed: 'https://iframe.mediadelivery.net/embed/449741/096b2a96-cb99-4581-92a8-50e5580b3688?autoplay=true&loop=false&muted=false&preload=true&responsive=true',
  },
  {
    composer: 'Modest Mussorgsky',
    title: 'Pictures at an Exhibition',

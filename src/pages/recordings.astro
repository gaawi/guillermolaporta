    role: 'Flute · Arr.',
    type: 'video',
    cover: `${WP}/pictures2.jpg`,
    embed: 'https://iframe.mediadelivery.net/embed/449741/b4dc09b9-0cfa-41a4-b6b8-101953bfaee5?autoplay=true&loop=false&muted=false&preload=true&responsive=true',
  },
  {
    composer: 'Joan Tower',
    title: 'Petroushkates',
    year: '2023',
    role: 'Flute',
    type: 'audio',
    cover: `${WP}/016.jpg`,
    tracks: [
      { label: 'Petroushkates', src: `${WP}/Petroushkates.mp3` },
    ],
  },
  {
    composer: 'Marcos Fernández',
    title: 'Noctum — Concerto for flute and clarinet',
    year: '2022',

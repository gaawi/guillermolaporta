---
import AppLayout from '../layouts/AppLayout.astro';
import { liveRecordings } from '../data/site.js';

const _base = import.meta.env.BASE_URL || '/';
const b = _base.endsWith('/') ? _base : _base + '/';

function imgSrc(src) {
  if (!src) return '';
  if (src.startsWith('http')) return src;
  return `${b}${src.replace(/^\//, '')}`;
}

function playUrl(cover) {
  const slug = cover.replace('/covers/', '').replace('.jpg', '');
  return `https://play.creartbox.nyc/title/${slug}/`;
}

const arrangementComposers = new Set([
  'Shostakovich', 'Haydn', 'Mahler · CreArtBox · Le Train Bleu',
]);

const recordings = liveRecordings.map(r => ({
  ...r,
  role: arrangementComposers.has(r.composer) ? 'Flute · Arr.' : 'Flute',
  format: parseInt(r.year) >= 2023 ? 'HD' : 'HD',
  playUrl: playUrl(r.cover),
}));

// Sort: newest first
recordings.sort((a, b) => parseInt(b.year) - parseInt(a.year));
---
<AppLayout
  title="Recordings — Guillermo Laporta"
  description="Concert recordings of Guillermo Laporta as flutist — chamber music, orchestral transcriptions and original works."
>
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">Recordings</div>
    <h1 class="subpage-title">As a <em>flutist</em>.</h1>
    <p class="subpage-sub">Concert recordings — chamber music, orchestral transcriptions and original works. Stream at full quality on CreArtBox Play.</p>
  </div>

  <section class="rec-section">
    <div class="rec-grid">
      {recordings.map((r) => (
        <article class="rec-card">
          <a class="rec-link" href={r.playUrl} target="_blank" rel="noopener">
            <div class="rec-cover">
              <img src={imgSrc(r.cover)} alt={r.title} loading="lazy" />
              <div class="rec-play-icon">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            </div>
            <div class="rec-body">
              <div class="rec-composer">{r.composer}</div>
              <h2 class="rec-title">{r.title}</h2>
              <div class="rec-foot">
                <span class="rec-year">{r.year}</span>
                <span class="rec-badge role">{r.role}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="rec-cta">
      <a class="rec-cta-link" href="https://play.creartbox.nyc/media-cast/guillermo-laporta-flute/" target="_blank" rel="noopener">
        Full library on CreArtBox Play
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
      </a>
    </div>
  </section>

  <style>
    .rec-section {
      max-width: 1480px;
      margin: 0 auto;
      padding: 0 40px 96px;
    }
    @media (max-width: 720px) {
      .rec-section { padding: 0 20px 64px; }
    }

    .rec-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
    }
    @media (max-width: 1100px) { .rec-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 600px)  { .rec-grid { grid-template-columns: 1fr; } }

    .rec-card {
      background: var(--surface);
      border: 1px solid var(--line-soft);
      overflow: hidden;
    }

    .rec-link {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      height: 100%;
    }

    .rec-cover {
      position: relative;
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background: var(--line-soft);
    }

    .rec-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform .5s ease, filter .3s ease;
    }

    .rec-play-icon {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .2s ease;
      background: rgba(0, 0, 0, .35);
    }

    .rec-play-icon svg {
      width: 44px;
      height: 44px;
      color: #fff;
      filter: drop-shadow(0 2px 8px rgba(0,0,0,.4));
    }

    .rec-card:hover .rec-cover img {
      transform: scale(1.03);
      filter: brightness(.85);
    }

    .rec-card:hover .rec-play-icon {
      opacity: 1;
    }

    .rec-body {
      padding: 20px 22px 22px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .rec-composer {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .rec-title {
      font-family: var(--serif);
      font-size: 17px;
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: -.01em;
      color: var(--ink);
      margin-bottom: 14px;
      flex: 1;
      transition: color .15s;
    }

    .rec-card:hover .rec-title { color: var(--accent); }

    .rec-foot {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .rec-year {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .12em;
      color: var(--muted);
    }

    .rec-badge {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border: 1px solid var(--line-soft);
      color: var(--muted);
    }

    .rec-badge.role {
      border-color: var(--accent);
      color: var(--accent);
    }

    .rec-cta {
      margin-top: 56px;
      text-align: center;
    }

    .rec-cta-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      border-bottom: 1px solid var(--line-soft);
      padding-bottom: 3px;
      transition: color .15s, border-color .15s;
    }

    .rec-cta-link:hover { color: var(--accent); border-color: var(--accent); }

    .rec-cta-link svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .rec-body { padding: 16px 18px 18px; }
      .rec-title { font-size: 16px; }
    }
  </style>
</AppLayout>

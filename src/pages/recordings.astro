  },
  {
    composer: 'Olivier Messiaen',
    title: 'Quartet for the End of Time',
    year: '2019',
    role: 'Flute',
    type: 'audio',
    cover: `${WP}/ADS_0835.jpg`,
    tracks: [
      { label: 'I – Crystal liturgy', src: `${CDN}/webimg/audios/20190830/01%20Crystal%20liturgy.mp3` },
      { label: 'II – Vocalise, for the Angel', src: `${CDN}/webimg/audios/20190830/02%20Vocalise%2C%20for%20the%20Angel%20who%20announces%20the%20end%20of%20time.mp3` },
      { label: 'III – Abyss of birds', src: `${CDN}/webimg/audios/20190830/03%20Abyss%20of%20birds.mp3` },
      { label: 'IV – Interlude', src: `${CDN}/webimg/audios/20190830/04%20Interlude.mp3` },
      { label: 'V – Praise to the eternity of Jesus', src: `${CDN}/webimg/audios/20190830/05%20Praise%20to%20the%20eternity%20of%20Jesus.mp3` },
      { label: 'VI – Dance of fury', src: `${CDN}/webimg/audios/20190830/06%20Dance%20of%20fury%2C%20for%20the%20seven%20trumpets.mp3` },
      { label: 'VII – Tangle of rainbows', src: `${CDN}/webimg/audios/20190830/07%20Tangle%20of%20rainbows%2C%20for%20the%20Angel%20who%20announces%20the%20end%20of%20time.mp3` },
      { label: 'VIII – Praise to the immortality of Jesus', src: `${CDN}/webimg/audios/20190830/08%20Praise%20to%20the%20immortality%20of%20Jesus.mp3` },
    ],
  },
];
---
<AppLayout
  title="Recordings — Guillermo Laporta"
  description="Concert recordings of Guillermo Laporta as flutist — chamber music, original works and orchestral transcriptions."
>
  <div class="subpage-head">
    <a class="subpage-back" href={b}>← Home</a>
    <div class="subpage-num">Recordings</div>
    <h1 class="subpage-title">As a <em>flutist</em>.</h1>
    <p class="subpage-sub">Concert recordings — chamber music, new works and orchestral transcriptions. Press play to listen or watch.</p>
  </div>

  <section class="rec-section">
    <ul class="rec-list">
      {recordings.map((r, i) => (
        <li class="rec-row">
          <div class="rec-thumb">
            <img src={r.cover} alt={r.title} loading="lazy" />
          </div>
          <div class="rec-info">
            <div class="rec-composer">{r.composer}</div>
            <h2 class="rec-title">{r.title}</h2>
            <div class="rec-meta">
              <span class="rec-year">{r.year}</span>
              <span class={`rec-badge ${r.role.includes('Arr') ? 'arr' : ''}`}>{r.role}</span>
              {r.note && <span class="rec-note">{r.note}</span>}
            </div>
          </div>
          <div class="rec-action">
            <button
              class={`rec-play-btn ${r.type}`}
              data-index={i}
              aria-label={r.type === 'video' ? `Watch ${r.title}` : `Listen to ${r.title}`}
            >
              {r.type === 'video'
                ? (<><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg> Watch</>)
                : (<><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 18V6l13-2v12M9 18a3 3 0 1 1-6 0 3 3 0 0 1 6 0m13-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/></svg> Listen</>)
              }
            </button>
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ── MODAL ─────────────────────────────────────────────────────── -->
  <div class="media-modal" id="mediaModal" role="dialog" aria-modal="true">
    <div class="modal-backdrop" id="modalBackdrop"></div>
    <div class="modal-box" id="modalBox">
      <button class="modal-close" id="modalClose" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>

      <!-- Video panel -->
      <div class="modal-video-panel" id="modalVideoPanel">
        <div class="modal-iframe-wrap">
          <iframe id="modalIframe" src="" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
        <div class="modal-video-info" id="modalVideoInfo"></div>
      </div>

      <!-- Audio panel -->
      <div class="modal-audio-panel" id="modalAudioPanel">
        <div class="modal-audio-cover">
          <img id="modalAudioCover" src="" alt="" />
        </div>
        <div class="modal-audio-content">
          <div class="modal-audio-meta" id="modalAudioMeta"></div>
          <audio id="modalAudio" controls></audio>
          <ul class="modal-track-list" id="modalTrackList"></ul>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ recordings }}>
    const modal       = document.getElementById('mediaModal');
    const backdrop    = document.getElementById('modalBackdrop');
    const closeBtn    = document.getElementById('modalClose');
    const videoPanel  = document.getElementById('modalVideoPanel');
    const audioPanel  = document.getElementById('modalAudioPanel');
    const iframe      = document.getElementById('modalIframe');
    const videoInfo   = document.getElementById('modalVideoInfo');
    const audioEl     = document.getElementById('modalAudio');
    const audioCover  = document.getElementById('modalAudioCover');
    const audioMeta   = document.getElementById('modalAudioMeta');
    const trackList   = document.getElementById('modalTrackList');

    function openModal(idx) {
      const r = recordings[idx];
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';

      if (r.type === 'video') {
        videoPanel.style.display = '';
        audioPanel.style.display = 'none';
        iframe.src = r.embed;
        videoInfo.innerHTML = `<span class="modal-composer">${r.composer}</span> <span class="modal-title-text">${r.title}</span>`;
      } else {
        videoPanel.style.display = 'none';
        audioPanel.style.display = '';
        iframe.src = '';
        audioCover.src  = r.cover;
        audioCover.alt  = r.title;
        audioMeta.innerHTML = `<span class="modal-composer">${r.composer}</span><span class="modal-title-text">${r.title}</span>`;

        trackList.innerHTML = '';
        r.tracks.forEach((t, ti) => {
          const li = document.createElement('li');
          li.className = 'modal-track' + (ti === 0 ? ' active' : '');
          li.dataset.src = t.src;
          li.innerHTML = `<span class="track-num">${String(ti + 1).padStart(2, '0')}</span><span class="track-label">${t.label}</span>`;
          li.addEventListener('click', () => playTrack(li, t.src));
          trackList.appendChild(li);
        });
        playTrack(trackList.querySelector('.modal-track'), r.tracks[0].src);
      }
    }

    function playTrack(li, src) {
      trackList.querySelectorAll('.modal-track').forEach(t => t.classList.remove('active'));
      li.classList.add('active');
      audioEl.src = src;
      audioEl.play().catch(() => {});
    }

    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
      iframe.src = '';
      audioEl.pause();
      audioEl.src = '';
    }

    document.querySelectorAll('.rec-play-btn').forEach(btn => {
      btn.addEventListener('click', () => openModal(Number(btn.dataset.index)));
    });
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  </script>

  <style>
    /* ── list layout ── */
    .rec-section {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 40px 96px;
    }
    @media (max-width: 720px) { .rec-section { padding: 0 20px 64px; } }

    .rec-list {
      list-style: none;
      border-top: 1px solid var(--line-soft);
    }

    .rec-row {
      display: grid;
      grid-template-columns: 80px 1fr auto;
      gap: 24px;
      align-items: center;
      padding: 20px 0;
      border-bottom: 1px solid var(--line-soft);
      transition: background .15s;
    }
    .rec-row:hover { background: var(--surface); margin: 0 -16px; padding-left: 16px; padding-right: 16px; }

    .rec-thumb {
      width: 80px;
      height: 80px;
      flex-shrink: 0;
      overflow: hidden;
      background: var(--line-soft);
    }
    .rec-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .rec-info { min-width: 0; }

    .rec-composer {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .rec-title {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 400;
      line-height: 1.2;
      letter-spacing: -.01em;
      color: var(--ink);
      margin-bottom: 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .rec-meta {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .rec-year {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .12em;
      color: var(--muted);
    }

    .rec-badge {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border: 1px solid var(--line-soft);
      color: var(--muted);
    }

    .rec-badge.arr { border-color: var(--accent); color: var(--accent); }

    .rec-note {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--muted);
      font-style: italic;
    }

    .rec-play-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .14em;
      text-transform: uppercase;
      padding: 9px 18px;
      border: 1px solid var(--line-soft);
      background: transparent;
      color: var(--ink);
      cursor: pointer;
      white-space: nowrap;
      transition: all .15s;
    }
    .rec-play-btn svg { width: 14px; height: 14px; flex-shrink: 0; }
    .rec-play-btn:hover, .rec-play-btn.video:hover { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .rec-play-btn.audio:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

    @media (max-width: 720px) {
      .rec-row { grid-template-columns: 64px 1fr; gap: 16px; }
      .rec-thumb { width: 64px; height: 64px; }
      .rec-title { font-size: 15px; }
      .rec-action { grid-column: 1 / -1; padding-left: 80px; }
      .rec-play-btn { padding: 7px 14px; font-size: 9px; }
    }
    @media (max-width: 480px) {
      .rec-action { padding-left: 0; }
    }

    /* ── modal ── */
    .media-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s ease;
    }
    .media-modal.open { opacity: 1; pointer-events: auto; }

    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, .88);
      cursor: pointer;
    }

    .modal-box {
      position: relative;
      z-index: 1;
      width: min(900px, 95vw);
      max-height: 90vh;
      overflow-y: auto;
      background: var(--paper);
      box-shadow: 0 32px 80px rgba(0,0,0,.6);
      transform: translateY(12px);
      transition: transform .25s ease;
    }
    .media-modal.open .modal-box { transform: translateY(0); }

    .modal-close {
      position: absolute;
      top: 16px;
      right: 16px;
      z-index: 2;
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0,0,0,.5);
      border: none;
      border-radius: 50%;
      color: #fff;
      cursor: pointer;
      transition: background .15s;
    }
    .modal-close:hover { background: rgba(0,0,0,.8); }
    .modal-close svg { width: 18px; height: 18px; }

    /* video panel */
    .modal-video-panel { display: flex; flex-direction: column; }
    .modal-iframe-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      background: #000;
      overflow: hidden;
    }
    .modal-iframe-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    .modal-video-info {
      padding: 16px 24px;
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    /* audio panel */
    .modal-audio-panel {
      display: flex;
      gap: 0;
    }
    .modal-audio-cover {
      width: 220px;
      flex-shrink: 0;
    }
    .modal-audio-cover img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .modal-audio-content {
      flex: 1;
      padding: 28px 28px 24px;
      display: flex;
      flex-direction: column;
      min-width: 0;
    }
    .modal-audio-meta {
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin-bottom: 20px;
    }

    /* shared info styles */
    .modal-composer {
      font-family: var(--mono);
      font-size: 10px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .modal-title-text {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 400;
      color: var(--ink);
    }
    .modal-video-info .modal-title-text { font-size: 16px; }

    #modalAudio {
      width: 100%;
      margin-bottom: 20px;
      accent-color: var(--accent);
    }

    .modal-track-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      flex: 1;
      overflow-y: auto;
      max-height: 220px;
    }
    .modal-track {
      display: flex;
      align-items: baseline;
      gap: 12px;
      padding: 9px 0;
      border-bottom: 1px solid var(--line-soft);
      cursor: pointer;
      transition: color .15s;
    }
    .modal-track:last-child { border-bottom: none; }
    .modal-track:hover, .modal-track.active { color: var(--accent); }
    .track-num { font-family: var(--mono); font-size: 10px; color: var(--muted); min-width: 20px; flex-shrink: 0; }
    .track-label { font-size: 13px; line-height: 1.3; }

    @media (max-width: 600px) {
      .modal-audio-panel { flex-direction: column; }
      .modal-audio-cover { width: 100%; height: 200px; }
      .modal-audio-cover img { height: 100%; }
      .modal-audio-content { padding: 20px; }
    }
  </style>
</AppLayout>
